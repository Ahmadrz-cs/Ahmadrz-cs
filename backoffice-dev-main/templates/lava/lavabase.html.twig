<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>{% block html_title %}{% endblock html_title %} - {{ app_system_name }}</title>
    <meta content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" name="viewport">
    <link rel="icon" type="image/png" href="{{ asset('build/images/favicon-96x96.png') }}" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="{{ asset('build/images/favicon.svg') }}" />
    <link rel="shortcut icon" href="{{ asset('build/images/favicon.ico') }}" />
    {% block stylesheets %}
    {{ encore_entry_link_tags('auth') }}
    {% endblock stylesheets %}
</head>

<body class="hold-transition {% block pageclass %}{% endblock pageclass %}" ng-app="{{ app_system_name }}">
    {% block body %}{% endblock body %}
    {% block modal %}{% endblock modal %}

    {% block javascripts %}
    {{ encore_entry_script_tags('auth') }}
    {% endblock javascripts %}
</body>

</html>