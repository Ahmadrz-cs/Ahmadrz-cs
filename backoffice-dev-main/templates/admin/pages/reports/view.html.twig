{% extends 'admin/layouts/cms.html.twig' %}

{% set backToRoute = 'admin_reports_index' %}
{% set areaHeading = 'Reports' %}
{% set mainHeading = 'Report' %}
{% set maturityLabel = 'beta' %}

{% set statusToColor = {
    'available': 'green',
    'pending': 'yellow',
    'draft': 'gray',
    'cancelled': 'red',
} %}

{% block page_content %}
    {% embed 'admin/components/_bordered_section.html.twig' with {
        "sectionId": 'report-info',
        "sectionTitle": 'Report Information',
        "linkActions": [
            {
				"text": "Download Report",
				"route": "admin_reports_download",
				"params": {
                    id: report.id
                },
				"style": "btn-dark",
                "render": report.url is not empty,
			},
            {
				"text": "Check for Updates",
				"route": "admin_reports_check_update",
				"params": {
                    id: report.id
                },
				"style": "btn-outline-dark",
                "render": report.url is empty or report.status == constant('\\App\\Entity\\Enum\\ReportStatus::Pending'),
			},
            {
				"text": "View Mangopay Report Config",
				"route": "admin_reports_mangopay_view",
				"params": {
                    id: report.referenceId
                },
				"style": "btn-outline-dark",
                "render": report.referenceId is not empty and report.origin == constant('\\App\\Entity\\Report::ORIGIN_MANGOPAY'),
			},
        ]
    } %}
        {% block sectionContent %}

            <div class="table-responsive">
                <table class="table">
                    <thead></thead>
                    <tbody>
                        <tr data-field-name="id">
                            <td>Report Id</td>
                            <td>{{ report.id }}</td>
                        </tr>
                        <tr data-field-name="description">
                            <td>Description</td>
                            <td>{{ report.description }}</td>
                        </tr>
                        <tr data-field-name="origin">
                            <td>Origin</td>
                            <td>{{ report.origin|capitalize }}</td>
                        </tr>
                        <tr data-field-name="resource">
                            <td>Resource Id</td>
                            <td>{{ report.resourceId }}</td>
                        </tr>
                        <tr data-field-name="reference">
                            <td>Reference Id</td>
                            <td>{{ report.referenceId }}</td>
                        </tr>
                        <tr data-field-name="url">
                            <td>Download Url</td>
                            <td>{{ report.url }}</td>
                        </tr>
                        <tr data-field-name="status">
                            <td>Status</td>
                            <td>{{ report.status.value|capitalize }}</td>
                        </tr>
                        <tr data-field-name="step">
                            <td>Step</td>
                            <td>{{ report.step }}</td>
                        </tr>
                        <tr>
                            <td>Created At</td>
                            <td>{{ report.createdAt|date() }} by {{ report.createdBy|default('N/A') }}</td>
                        </tr>
                        <tr>
                            <td>Updated At</td>
                            <td>{{ report.updatedAt|date() }} by {{ report.updatedBy|default('N/A') }}</td>
                        </tr>
                    </tbody>
                </table>
            </div>
            {{ form_start(form) }}
            {{ form_widget(form.delete) }}
            {{ form_rest(form) }}
            {{ form_end(form) }}
        {% endblock %}
    {% endembed %}

    {% embed 'admin/components/_bordered_section.html.twig' with {
        "sectionId": 'report-sets',
        "sectionTitle": 'Report Sets',
        "linkActions": []
    } %}
        {% block sectionContent %}

            {{ include('admin/components/_alert.html.twig', {
                variant: "info",
                message: "This section shows all report sets that this report is part of",
            }) }}

            <div class="table-responsive">
                <table class="table" id="report-sets-list">
                    <thead>
                        <tr>
                            <th>Actions</th>
                            <th>Id</th>
                            <th>Type</th>
                            <th>Asset</th>
                            <th>Description</th>
                            <th>Period Start</th>
                            <th>Period End</th>
                            <th class="text-end">Reports</th>
                            <th>Created At</th>
                            <th>Progress</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for reportSet in report.reportSets %}
                        <tr class="tw-text-sm" data-object-id="{{ reportSet.id }}">
                            <td><a class="btn btn-outline-primary text-nowrap"
                                href="{{ path('admin_report_set_view', { 
                                id: reportSet.id }
                            ) }}">View</a></td>
                            <td>{{ reportSet.id }}</td>
                            <td>{{ reportSet.reportSetType.value|capitalize }}</td>
                            <td>{% if reportSet.asset is not null %}<a href="{{ path('admin_product_dashboard', { 
                                    id: reportSet.asset.id }
                                ) }}">#{{ reportSet.asset.id }} // {{ reportSet.asset.name }} ({{ reportSet.asset.companyNumber }})</a>
                                {% else %}'N/A'{% endif %}
                            </td>
                            <td>{{ reportSet.description }}</td>
                            <td class="tw-tabular-nums">{{ reportSet.periodStart ? reportSet.periodStart|date('Y-m-d H:i') : 'N/A' }}</td>
                            <td class="tw-tabular-nums">{{ reportSet.periodEnd ? reportSet.periodEnd|date('Y-m-d H:i') : 'N/A' }}</td>
                            <td class="text-end tw-tabular-nums">{{ reportSet.reports|length }}</td>
                            <td class="tw-tabular-nums">{{ reportSet.createdAt|date('Y-m-d H:i') }}</td>
                            <td>
                                <span class="d-flex gap-2 align-items-center">
                                    {{ include('admin/components/_indicator.html.twig', {color: statusToColor[reportSet.status.value]|default('gray') }) }}
                                    {{ reportSet.status.value|capitalize }}
                                </span>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endblock %}
    {% endembed %}

{% endblock page_content %}
