{% extends 'admin/layouts/filtered_list.html.twig' %}

{% set areaHeading = 'Onboarding' %}
{% set mainHeading = 'Categorisations' %}
{% set maturityLabel = 'beta' %}
{% set baseTemplate = 'onboarding' %}

{% block foreword %}
    {% embed 'admin/components/_bordered_section.html.twig' with {
        "sectionId": "categorisations-summary",
        "sectionTitle": "Summary",
        "linkActions": [
            {
                "text": "Export All Categorisations",
                "route": "admin_onboarding_categorisation_export",
                "params": {},
                "style": "btn-outline-dark",
            },
        ]
    } %}
        {% block sectionContent %}
            {% set total = categoryCounts|reduce((carry, v) => carry + v.count) %}
            <table class="table">
                <thead>
                    <tr>
                        <th>Category</th>
                        <th>Count</th>
                    </tr>
                </thead>
                <tbody>
                    {% for counts in categoryCounts %}
                        <tr>
                            <td>{{ counts.category|capitalize }}</td>
                            <td>{{ counts.count }}</td>
                        </tr>
                    {% endfor %}
                    <tr>
                        <td>Total</td>
                        <td>{{ total }}</td>
                    </tr>
                </tbody>
            </table>

        {% endblock %}
    {% endembed %}
{% endblock %}

{% block filterPresets %}
    <a href="{{ path(app.request.attributes.get('_route'), { category: constant('App\\Entity\\Enum\\UserCategory::Restricted').value }) }}" class="btn btn-light">Restricted Only</a>
    <a href="{{ path(app.request.attributes.get('_route'), { category: constant('App\\Entity\\Enum\\UserCategory::Sophisticated').value }) }}" class="btn btn-light">Sophisticated Only</a>
    <a href="{{ path(app.request.attributes.get('_route'), { category: constant('App\\Entity\\Enum\\UserCategory::HighNetWorth').value }) }}" class="btn btn-light">High Net Worth Only</a>
{% endblock %}

{% block collapsibleFilters %}
    <div class="col-sm-6 col-md-4 col-xl-3">{{ form_row(form.id) }}</div>
    <div class="col-sm-6 col-md-4 col-xl-3">{{ form_row(form.verified) }}</div>
    <div class="col-sm-6 col-md-4 col-xl-3">{{ form_row(form.category) }}</div>
{% endblock %}

{% block collapsibleFiltersRange %}
    <div class="col-sm-6 col-md-4 col-xl-3">{{ form_row(form.createdAt_gte) }}</div>
    <div class="col-sm-6 col-md-4 col-xl-3">{{ form_row(form.createdAt_lt) }}</div>
{% endblock %}

{% block table %}
    {{ include('admin/components/_alert.html.twig', {
        variant: "info",
        title: "PS22/10 enforcement",
        message: "All users are required to review their category every 12 months",
    }) }}
    <table class="table" id="categorisations-list">
        <thead>
            <tr>
                <th>Actions</th>
                <th>Id</th>
                <th>User</th>
                <th>Category</th>
                <th>Details</th>
                <th>Staff Notes</th>
                <th>Manually Verified?</th>
                <th>Verified By</th>
                <th>Created By</th>
                <th>Created</th>
                <th>Last Updated</th>
            </tr>
        </thead>
        <tbody>
            {% for ctg in objects %}
                <tr>
                    <td>
                        <div class="d-flex flex-wrap gap-1">
                            {{ include('admin/components/button_link.html.twig', {
                                        linkProps: {
                                            "text": "Edit",
                                            "route": 'admin_onboarding_categorisation_edit',
                                            "params": {id: ctg.id},
                                            "style": "btn-outline-dark text-nowrap",
                                        },
                                    }) }}
                        </div>
                    </td>
                    <td data-field="id">{{ ctg.Id }}</td>
                    <td>
                        <a href="{{ path('admin_user_dashboard_overview', { 
                            id: ctg.profile.user.id
                        }) }}">{{ ctg.profile.user.fullname }}</a>
                    </td>
                    <td data-field="category">{{ ctg.category.name|humanize }}</td>
                    <td data-field="details">{{ ctg.details|json_encode }}</td>
                    <td data-field="notes">{{ ctg.notes }}</td>
                    <td data-field="is-verified">{{ ctg.verified ? 'Yes' : 'No' }}</td>
                    <td data-field="verified-by">{{ ctg.verifiedBy|default('-') }}</td>
                    <td data-field="created-by">{{ ctg.createdBy }}</td>
                    <td>{{ ctg.createdAt ? ctg.createdAt|date('Y-m-d H:i:s') : '-' }}</td>
                    <td>{{ ctg.updatedAt ? ctg.updatedAt|date('Y-m-d H:i:s') : '-' }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}
