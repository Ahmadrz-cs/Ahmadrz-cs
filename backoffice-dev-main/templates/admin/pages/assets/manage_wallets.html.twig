{% extends 'admin/layouts/col_1.html.twig' %}

{% set backToRoute = 'admin_asset_wallet_list' %}
{% set areaHeading = 'Assets' %}
{% set mainHeading = 'Manage Asset Wallets' %}

{% block page_content %}

	{% embed 'admin/components/_bordered_section.html.twig' with {
        "sectionId": "asset-wallet-overview",
        "sectionTitle": "Asset Wallet Overview",
        "linkActions": [
            {
                "text": "Create Missing Wallets",
                "route": "admin_asset_wallets_create_all",
                "params": { asset: asset.id },
                "style": "btn-primary",
            },
            {
                "text": "Refresh Wallet Balances",
                "route": app.request.attributes.get('_route'),
                "params": app.request.attributes.get('_route_params')|merge({"loadWallets": true}),
                "style": "btn-outline-secondary",
            },
        ]
    } %}
		{% block sectionContent %}
			<div class="row g-3">
				{{ include('admin/components/stat.html.twig', {
					key: 'Asset',
					value: '#%s // %s (%s)'|format(asset.id, asset.name, asset.companyNumber),
					className: 'col-12 col-md-6'
				}) }}
				{{ include('admin/components/stat.html.twig', {
					key: 'Last Checked',
					value: 'now'|date(constant('DATE_RFC822')),
					className: 'col-12 col-md-6'
				}) }}
			</div>
			{{ include('admin/components/_alert.html.twig', {
                variant: "notice",
                message: 'To load the wallet balances and other details, click "Refresh Wallet Balances". Also note that the "settlement" wallet is also known as the "main" or the "actual" wallet',
            }) }}
			<div class="table-responsive">
				<table class="table table-striped table-bordered mt-3 mb-0">
					<thead>
						<tr>
							<th>Actions</th>
							<th>Type</th>
							<th>Wallet Id</th>
							<th>Wallet Owner</th>
							<th>Description</th>
							<th class="text-end">Balance (£)</th>
							{# <th>Last Checked</th> #}
							
						</tr>
					</thead>
					<tbody>
						{% for wallet in wallets %}
							<tr data-wallet-type={{ wallet.type }}>
								<td>
									{% if wallet.walletId is empty %}
										<a href="{{ path('admin_asset_wallets_create', { asset: asset.id, type: wallet.type }) }}">Create Wallet</a>
									{% else %}
										<a href="{{ path('admin_product_dashboard', { id: asset.id }) }}">Edit Asset</a>
										<a class="ms-3" href="{{ path('admin_wallet_edit', { walletId: wallet.walletId }) }}">Edit Description</a>
										<a class="ms-3" href="{{ path('admin_wallet_transactions', { walletId: wallet.walletId }) }}">View Transactions</a>
									{% endif %}
								</td>
								<td>{{ wallet.type|capitalize }}</td>
								<td>
									{% if wallet.walletId is null %}
										<span class="badge text-bg-warning">Missing</span>
									{% else %}
										{{ wallet.walletId }}
									{% endif %}
								</td>
								<td>{{ wallet.owner|default('-') }}</td>
								<td>{{ wallet.description|default('-') }}</td>
								<td class="text-end tw-tabular-nums">{{ wallet.balance|default('0')|number_format(2, '.', ',') }}</td>
								{# <td>{{ wallet.lastChecked|date(constant('DATE_ATOM')) }}</td> #}
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		{% endblock %}
	{% endembed %}

{% endblock page_content %}
