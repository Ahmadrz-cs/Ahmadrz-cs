{% extends 'admin/layouts/cms.html.twig' %}

{% if is_granted('CAN_UPDATE_ASSET', app.user) %}
    {% if asset.id %}
        {% set titleText = 'Edit Asset' %}
    {% else %}
        {% set titleText = 'Add Asset' %}
    {% endif %}
{% else %}
    {% set titleText = 'View Asset' %}
{% endif %}

{% set backToRoute = 'admin_asset_index' %}
{% set areaHeading = 'Assets' %}
{% set mainHeading = titleText %}
{% set htmlTitle = titleText %}

{% block page_content %}

    <div class="d-flex flex-wrap gap-2">
        <a href="{{ path('admin_asset_index') }}" class="btn btn-secondary">Cancel</a>
        {% if asset.id %}
            <a href="{{ path('admin_product_dashboard', { id: asset.id }) }}" class="btn btn-dark">Go to Product Dashboard</a>
            <a href="/admin/assetdocument/add?asset={{ asset.id }}" class="btn btn-success">Add Document</a>
        {% endif %}
    </div>

    {% if asset.id is empty %}
        {% embed 'admin/components/_bordered_section.html.twig' with {
            "sectionId": "dashboard-prompt",
            "sectionTitle": "Launching a New Asset?",
            "sectionStyle": "border rounded-3 p-3 p-lg-4 border-warning",
            "linkActions": [
                    {
                        "text": "Go to new Asset Creator",
                        "route": "admin_product_create",
                        "params": {},
                        "style": "btn-success",
                    },
                ]
        } %}
            {% block sectionContent %}
                {{ include('admin/components/_alert.html.twig', {
                    variant: "notice",
                    message: "If you are just launching a new asset, use the new asset creator rather creating a new asset from scratch. The new tool has a guided setup so you are less likely to miss important fields.",
                }) }}
            {% endblock %}
        {% endembed %}
    {% endif %}

    {{ form_start (form, {attr:{'ng-non-bindable': 'ng-non-bindable' }}) }}
    <div class="nav-tabs-custom">
        <ul class="nav nav-tabs">
            <li class="nav-item">
                <a class="nav-link active" href="#main" data-bs-toggle="tab">Basic Details</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#contact" data-bs-toggle="tab">Contact Details</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#legal" data-bs-toggle="tab">Legal Details</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#finance" data-bs-toggle="tab">Finance Details</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#fee" data-bs-toggle="tab">Fees</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#team" data-bs-toggle="tab">Team</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#address" data-bs-toggle="tab">Address</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#custom-fields" data-bs-toggle="tab">Additional Fields</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#documents" data-bs-toggle="tab">Documents</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#status-record" data-bs-toggle="tab">Status Record</a>
            </li>
        </ul>
        <div class="tab-content p-3">
            <div class="tab-pane active" id="main">
                {{ form_row( form.name ) }}
                {{ form_row( form.alternateName ) }}
                {{ form_row( form.briefDescription ) }}

                {{ form_row( form.displayName ) }}
                {{ form_row( form.detailedDesc ) }}
                {{ form_row( form.assetType ) }}
                {{ form_row( form.sector ) }}

                {{ form_row( form.pointsOfInterest ) }}
                {{ form_row( form.featured ) }}
                {{ form_row( form.buyRestricted ) }}
                {{ form_row( form.sellRestricted ) }}
                {{ form_row( form.additionalType ) }}
                {{ form_row( form.visibility ) }}
                {{ form_row( form.createdById ) }}
            </div>
            <!-- /.tab-pane -->
            <div class="tab-pane" id="contact">
                {{ form_row( form.orgEmail ) }}
                {{ form_row( form.telephone ) }}

            </div>
            <!-- /.tab-pane -->
            <div class="tab-pane" id="legal">
                {{ form_row( form.mangoPayUserId ) }}
                {{ form_row( form.holdWalletId) }}
                {{ form_row( form.settlementWalletId) }}

                {{ form_row( form.depositWalletId) }}
                {{ form_row( form.expensesWalletId ) }}
                {{ form_row( form.taxWalletId ) }}
                {{ form_row( form.distributionWalletId) }}
                {{ form_row( form.treasuryWalletId ) }}

                {{ form_row( form.companyNumber ) }}
                {{ form_row( form.taxId ) }}

            </div>
            <!-- /.tab-pane -->
            <div class="tab-pane" id="finance">
                {{ form_row( form.fundingGoal ) }}
                {{ form_row( form.pricePerShare ) }}
                {{ form_row( form.amountOfShares ) }}
                <br/>
                {{ form_row( form.stampDutyUser ) }}
                {{ form_row( form.investmentTerm ) }}
                {{ form_row( form.termStart ) }}
                {{ form_row( form.financialYearStart ) }}
                {{ form_row( form.netProjectedIncome ) }}
                {{ form_row( form.netProjectedYield ) }}
                <br/>
                {{ form_row( form.grossRentalReturnPA ) }}
                {{ form_row( form.netRentalReturnPA ) }}
                {{ form_row( form.grossCapitalAppreciation ) }}
                {{ form_row( form.netCapitalAppreciation ) }}
                {{ form_row( form.netCapitalAppreciationYield ) }}

            </div>
            <!-- /.tab-pane -->
            <div class="tab-pane" id="fee">
                <div class="d-flex flex-column gap-3">
                    <section>
                        <h3 class="fw-bold fs-4">Fees</h3>
                        {{ form_row( form.setupFee ) }}
                        {{ form_row( form.managementFee ) }}
                        {{ form_row( form.profitShare ) }}
                        {{ form_row( form.adminFee ) }}
                    </section>

                    <section class="d-flex flex-column gap-3">
                        <div>
                            <h3 class="fw-bold fs-4">Customisable Relisting Fees</h3>
                            <h4 class="fw-bold fs-5">Summary of Fee Bands</h4>
                            {% include 'admin/pages/assets/_default_relisting_fee.html.twig' with {'object': asset} only %}
                        </div>
                        <div>
                            <h4 class="fw-bold fs-5">Custom Fee Bands</h4>
                            {{ include('admin/components/_alert.html.twig', {
                                variant: "notice",
                                message: "TIP: Want to switch off the relisting fee on this asset? Add a custom fee band where both band start and fee cap are 0!",
                            }) }}
                            {% if is_granted('CAN_UPDATE_ASSET', app.user) %}
                                <button type="button" class="btn btn-success my-2" id="add-fee-field">Add Custom Fee Band</button>
                            {% endif %}

                            <div id="fee-fields-list" data-field-count={{ form.fees | length }} data-prototype="{{ form_widget(form.fees.vars.prototype)|e }}">
                                {% for field in form.fees %}
                                    <div id="fee-field-{{ loop.index0 }}" class="fee-field-container">
                                        <div>
                                            <i class="fa fa-times remove-fee-field pull-right "></i>
                                        </div>
                                        {{ form_widget( field ) }}
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    </section>
                </div>
            </div>
            <!-- /.tab-pane -->
            <div class="tab-pane" id="address">
                {% if is_granted('CAN_UPDATE_ASSET', app.user) %}
                    <button type="button" class="btn btn-success" id="add-address-field">Add New Address</button>
                {% endif %}
                <br/>
                <br/>
                {{ include('admin/components/_alert.html.twig', {
					variant: "info",
					title: "Multiple Addresses",
					message: "If there are multiple addresses, the most recent one (last one) will be considered the main/current address (highlighted by the indicator).",
				}) }}
                <div id="address-list" data-field-count={{ form.addresses | length }} data-prototype="{{ form_widget(form.addresses.vars.prototype)|e }}">
                    {% for field in form.addresses %}
                        <div id="address-field-{{ loop.index0 }}" class="address-field-container mt-3">
                            <div>
                                <i class="fa fa-times remove-address-field pull-right "></i>
                            </div>
                            {% if loop.index0 == (form.addresses | length) - 1 %}
								<span class="badge text-bg-dark my-2">Main Address</span>
							{% endif %}
                            {{ form_widget( field ) }}
                        </div>
                    {% endfor %}
                </div>
            </div>
            <!-- /.tab-pane -->
            <div class="tab-pane" id="team">
                {% if is_granted('CAN_UPDATE_ASSET', app.user) %}
                    <button type="button" class="btn btn-success" id="add-member-field">Add New Member</button>
                {% endif %}
                <br/>
                <br/>
                <div id="members-list" data-field-count={{ form.members | length }} data-prototype="{{ form_widget(form.members.vars.prototype)|e }}">
                    {% for member in form.members %}
                        <div id="member-field-{{ loop.index0 }}" class="member-field-container">
                            <div>
                                <i class="fa fa-times remove-member-field pull-right "></i>
                            </div>
                            {{ form_widget( member ) }}
                        </div>
                    {% endfor %}
                </div>
            </div>
            <!-- /.tab-pane -->
            <div class="tab-pane" id="custom-fields">
                {% if is_granted('CAN_UPDATE_ASSET', app.user) %}
                    <button type="button" class="btn btn-success" id="add-custom-field">Add New Field</button>
                {% endif %}
                <br/>
                <div id="custom-fields-list" data-field-count={{ form.addFields | length }} data-prototype="{{ form_widget(form.addFields.vars.prototype)|e }}">
                    {% if form.addFields is empty %}
                        {% do form.addFields.setRendered %}
                    {% endif %}
                    {% for field in form.addFields %}
                        <div id="custom-field-{{ loop.index0 }}" class="custom-field-container">
                            <div>
                                <i class="fa fa-times remove-custom-field pull-right "></i>
                            </div>
                            {{ form_widget( field ) }}
                        </div>
                    {% endfor %}
                </div>
            </div>
            <div class="tab-pane" id="documents">
                {% include 'admin/components/document-list.html.twig' with {'documents':asset.documents,'permision':'CAN_UPDATE_ASSET','add':'admin_assetdocument_add','edit':'admin_assetdocument_edit','actions':'asset_document'} only %}
            </div>
            <div class="tab-pane" id="status-record">
                <div class="d-flex flex-column gap-3">
                    {{ include('admin/components/status_record_table.html.twig', {
                        object: asset,
                        places: [
                            'draft',
                            'submitted',
                            'approved',
                            'published',
                            'archived',
                            'cancelled',
                            'rejected',
                        ]
                    }) }}
                    {% embed 'admin/components/_bordered_section.html.twig' with {
                        "sectionId": "status-section",
                        "sectionTitle": "Status",
                        "linkActions": [
                            {
                                "text": "Create State Transition and Log",
                                "route": "admin_asset_status_log_create",
                                "params": {id: asset.id},
                                "style": "btn-success",
                                "roleRequired": "ROLE_OPERATIONS",
                                "render": asset.id is not null
                            },
                        ]
                    } %}
                        {% block sectionContent %}
                        {{ include('admin/components/_alert.html.twig', {
                            variant: "notice",
                            message: "This is a new status record that supersedes the old/legacy one going forward. Legacy assets should be upgraded with a new status, otherwise the defaults (proposal/draft) will be shown. For backwards compatibility, the legacy status will remain in use.",
                        }) }}
                        <div class="row g-3">
                            {{ include('admin/components/stat.html.twig', {
                                key: 'Current Status',
                                value: asset.currentStatus.value|capitalize,
                                className: "col-md-6",
                            }) }}
                        </div>
                        <div class="table-responsive">
                            <h4 class="fw-bold fs-5">Status Logs</h4>
                            <table class="table" id="status-logs">
                                <thead>
                                    <tr>
                                        <th>Actions</th>
                                        <th>Id</th>
                                        <th>Status</th>
                                        <th>Notes</th>
                                        <th>Transitioned By</th>
                                        <th>OccuredAt</th>
                                        <th>CreatedAt</th>
                                        
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for status_log in asset.statusLogs|default([]) %}
                                    <tr data-object-id="{{ status_log.id }}">
                                        <td>{% if is_granted('ROLE_OPERATIONS') %}
                                            {{ include('admin/components/button_link.html.twig', {
                                                linkProps: {
                                                    "text": "Edit",
                                                    "route": "admin_asset_status_log_edit",
                                                    "params": {id: status_log.id},
                                                    "style": "btn-outline-secondary text-nowrap",
                                                },
                                            }) }}
                                        {% endif %}</td>
                                        <td data-field-name="id">{{ status_log.id }}</td>
                                        <td data-field-name="status">{{ status_log.status.value|capitalize }}</td>
                                        <td data-field-name="notes">{{ status_log.notes }}</td>
                                        <td data-field-name="transitioned-by">{{ status_log.transitionedBy.userIdentifier|default('System') }}</td>
                                        <td data-field-name="occured-at">{{ status_log.occuredAt|date('Y-m-d H:i:s') }}</td>
                                        <td>{{ status_log.createdAt|date('Y-m-d H:i:s') }}</td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                        {% endblock %}
                    {% endembed %}
                </div>
            </div>
            {% include 'admin/components/blame-timestamp.html.twig' with {'object': asset} only %}

            {# Don't render any multifields that are empty #}
            {% set multifields = [form.addFields, form.members, form.addresses, form.fees] %}
            {% for item in multifields %}
                {% if item is empty %}
                    {% do item.setRendered %}
                {% endif %}
            {% endfor %}
        </div>
        <!-- /.tab-content -->
    </div>
    {% if is_granted('CAN_UPDATE_ASSET', app.user) %}
        {{ form_widget(form.submit) }}
    {% endif %}
    {{ form_end( form ) }}

{% endblock page_content %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('field_custom') }}
    {{ encore_entry_script_tags('field_member') }}
    {{ encore_entry_script_tags('field_address') }}
    {{ encore_entry_script_tags('field_fee') }}
    {{ encore_entry_script_tags('form_required') }}
{% endblock javascripts %}
