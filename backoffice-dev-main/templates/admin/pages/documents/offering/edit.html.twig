{% extends 'admin/layouts/cms.html.twig' %}

{% if offeringdocument.id %}
	{% set titleText = 'Edit Offering Document' %}
{% else %}
	{% set titleText = 'Add Offering Document' %}
{% endif %}

{% set backToRoute = 'admin_offeringdocument_index' %}
{% set areaHeading = 'Documents' %}
{% set mainHeading = titleText %}

{% block page_content %}

	<div class="d-flex flex-wrap gap-2">
		<a href="{{ path('admin_offeringdocument_index') }}" class="btn btn-secondary">Cancel</a>
		{% if offeringdocument.id > 0 %}
			{{ include('admin/components/button_link.html.twig', {
				linkProps: {
					"text": "Download",
					"route": 'admin_document_download',
					"params": {
						'id': offeringdocument.document.id,
						'type':'public',
					},
					"style": "btn-outline-dark text-nowrap",
				},
			}) }}
			{{ include('admin/components/button_link.html.twig', {
				linkProps: {
					"text": "View",
					"route": 'admin_document_download',
					"params": {
						'id': offeringdocument.document.id,
						'type':'public',
						'preview': 1,
					},
					"style": "btn-outline-dark text-nowrap",
					"newTab": true,
				},
			}) }}
		{% endif %}
	</div>

	{{ form_start(form, {attr:{'ng-non-bindable': 'ng-non-bindable'}}) }}
	{{ form_row(form.offering, {attr: {'class': 'searchable'}}) }}
	{{ form_row(form.document) }}

	{% include 'admin/components/blame-timestamp.html.twig' with {'object': offeringdocument} only %}
	{{ form_widget(form.submit) }}
	{{ form_end(form) }}

{% endblock page_content %}
