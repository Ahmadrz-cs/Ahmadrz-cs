{% extends 'admin/layouts/col_1.html.twig' %}

{% set backToRoute = 'admin_maintenance_user_comms' %}
{% set areaHeading = 'Maintenance Tools' %}
{% set mainHeading = 'User Comms Cleanup' %}
{% set maturityLabel = 'beta' %}

{% form_theme form with ['bootstrap_5_layout.html.twig'] only %}

{% block page_content %}

    {% embed 'admin/components/_bordered_section.html.twig' with {
        "sectionId": "search-and-delete-user-comms",
        "sectionTitle": "Search and Delete User Comms",
    } %}
        {% block sectionContent %}
        {{ form_start(form) }}
        <div class="row">
            <div class="col-sm-6">{{ form_row(form.createdAt_lt) }}</div>
            <div class="col-sm-6">{{ form_row(form.subject) }}</div>
        </div>
        <div class="d-flex flex-wrap gap-2">
            {# <button class="btn btn-primary" id="submit" type="submit">Search Transfers</button> #}
            {{ form_widget( form.search, { 'attr': {'class': 'btn-primary'} } ) }}
            <a class="btn btn-outline-secondary"
                href="{{ path('admin_maintenance_user_comms') }}">Cancel</a>
            <a class="btn btn-outline-secondary"
                href="{{ path('admin_maintenance_user_comms_cleanup') }}">Reset Criteria to Default</a>
            {{ form_widget( form.delete, { 'attr': {
                'class': 'btn-danger',
                'onclick': "return confirm('Are You Sure? You cannot undo this action!')"
            } } ) }}
        </div>
        {{ form_end(form) }}
        {% endblock %}
    {% endembed %}

    {% embed 'admin/components/_bordered_section.html.twig' with {
        "sectionId": "emails-by-subject",
        "sectionTitle": "Emails by Subject Line",
    } %}
        {% block sectionContent %}
        {{ include('admin/components/_alert.html.twig', {
            variant: "info",
            message: "Chosen subject is highlighted in yellow. The other entries are for reference. If none are highlighted, then no emails before the chosen date were found.",
        }) }}
            
        <div class="row g-3">
            {{ include('admin/components/stat.html.twig', {
                key: 'Searching for Emails Older Than',
                value: form.vars.value.createdAt_lt|date('Y-m-d'),
                className: 'col-md-6'
            }) }}
            {{ include('admin/components/stat.html.twig', {
                key: 'Matches for Subject',
                value: (sizeBySubject|filter(e => e.subject == chosenSubject|default(""))|first)['count']|default(0),
                className: 'col-md-6'
            }) }}
        </div>
        <div class="overflow-auto">
            <table class="table" id="comms-list">
                <thead>
                    <tr>
                        <th>Subject Line</th>
                        <th>Count</th>
                    </tr>
                </thead>
                <tbody>
                    {% for entry in sizeBySubject|default([]) %}
                    <tr {% if chosenSubject == entry.subject %}class="bg-warning"{% endif %}
                    >
                        <td>{{ entry.subject }}</td>
                        <td>{{ entry.count }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% endblock %}
    {% endembed %}

{% endblock page_content %}
