{% extends 'admin/layouts/col_1.html.twig' %}

{% set areaHeading = 'Maintenance Tools' %}
{% set mainHeading = 'Activity Logs Cleanup' %}
{% set maturityLabel = 'beta' %}

{% form_theme form with ['bootstrap_5_layout.html.twig'] only %}

{% block page_content %}

    {% embed 'admin/components/_bordered_section.html.twig' with {
        "sectionId": "search-and-delete-ext-logs",
        "sectionTitle": "Search and Delete Activity Logs",
    } %}
        {% block sectionContent %}
        <div class="row g-3">
            {{ include('admin/components/stat.html.twig', {
                key: 'Logs Found',
                value: logCount ?? 0,
                className: 'col-md-6'
            }) }}
        </div>
        {{ form_start(form) }}
        <div class="row">
            <div class="col-sm-6">{{ form_row(form.dateEnd) }}</div>
        </div>
        {{ form_row(form.optimize) }}
        <div class="d-flex flex-wrap gap-2">
            {# <button class="btn btn-primary" id="submit" type="submit">Search Transfers</button> #}
            {{ form_widget( form.search, { 'attr': {'class': 'btn-primary'} } ) }}
            <a class="btn btn-outline-secondary"
                href="{{ path('admin_maintenance_activity_log_cleanup') }}">Reset Criteria to Default</a>
            {{ form_widget( form.delete, { 'attr': {
                'class': 'btn-danger',
                'onclick': "return confirm('Are You Sure? You cannot undo this action!')"
            } } ) }}
        </div>
        {{ form_end(form) }}
        {% endblock %}
    {% endembed %}

{% endblock page_content %}
