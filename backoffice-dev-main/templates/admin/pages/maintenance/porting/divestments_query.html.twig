{% extends 'admin/layouts/col_1_fluid.html.twig' %}

{% set backToRoute = 'admin_trade_system_porting_index' %}
{% set areaHeading = 'Trade System Porting Tools' %}
{% set mainHeading = 'Port Divestments' %}
{% set maturityLabel = 'alpha' %}

{# {% form_theme form with ['bootstrap_5_layout.html.twig'] only %} #}

{% block page_content %}

    {% embed 'admin/components/_bordered_section.html.twig' with {
        "sectionId": "divestments-analysis",
        "sectionTitle": "Divestments Analysis",
    } %}
        {% block sectionContent %}
        
        {% embed 'admin/components/_alert.html.twig' with {
            variant: "info",
            title: "Divestment Generations",
        } %}
            {% block message %}
                <ul>
                    <li>Generation 1 assets are those paid out before payment orders existed. These will be ported based on the investment and payout.</li>
                    <li>Generation 2 assets are those paid out with payment orders. These will be ported based on the payment order.</li>
                </ul>
            {% endblock message %}
        {% endembed %}

        {{ include('admin/components/_alert.html.twig', {
            variant: "info",
            title: "Shareholdings based on trade system",
            message: "The asset info shares circulating statistic is based on the trade system (share trades) rather than the legacy investment system",
        }) }}

        <table class="table table-bordered table-striped-columns" id="divestment-summary">
            <thead>
                <tr>
                    <th colspan="1" class="text-center">Common</th>
                    <th colspan="7" title="asset-info" class="text-center">Asset Info</th>
                    <th colspan="3" title="payout-info" class="text-center">Payout Info</th>
                    <th colspan="3" title="investment-info" class="text-center">Investment Info (Gen 1)</th>
                    <th colspan="3" title="order-info" class="text-center">Divestment Order Info (Gen 2)</th>
                    <th colspan="3" title="buyback-info" class="text-center">Buy Back Info</th>
                </tr>
                <tr>
                    <th>Action</th>

                    <th>Id</th>
                    <th>Name</th>
                    <th>SPV</th>
                    <th class="text-end">Price</th>
                    <th class="text-end">Issued</th>
                    <th class="text-end">Circulating</th>
                    <th>Status</th>

                    <th class="text-end">Count</th>
                    <th class="text-end">Paid</th>
                    <th class="text-end">Shares</th>
                    
                    <th class="text-end">Count</th>
                    <th class="text-end">Invested</th>
                    <th class="text-end">Shares</th>
                    
                    <th class="text-end">Count</th>
                    <th class="text-end">Paid</th>
                    <th class="text-end">Shares</th>

                    <th class="text-end">Count</th>
                    <th class="text-end">Paid</th>
                    <th class="text-end">Shares</th>
                </tr>
            </thead>
            <tbody>
                {% for item in divestmentsPaid %}
                <tr>
                    <td>
                    {{ include('admin/components/button_link.html.twig', {
                        linkProps: {
                            "text": "Check",
                            "route": "admin_trade_system_port_divestments_asset",
                            "params": {id: item.assetid},
                            "style": "btn-outline-primary text-nowrap",
                        },
                    }) }}
                    </td>

                    <td><a href="{{ path('admin_product_shareholders', { id: item.assetid }) }}">#{{ item.assetid }}</a></td>
                    <td>{{ item.assetName }}</td>
                    <td>{{ item.assetSpv }}</td>
                    <td class="tw-font-mono text-end">{{ item.assetSharePrice|string|format_currency('GBP') }}</td>
                    <td class="tw-font-mono text-end">{{ item.assetShareQuantity|number_format }}</td>
                    <td class="tw-font-mono text-end">{{ tradeHoldings[item.assetid].shares|number_format }}</td>
                    <td>{{ item.assetStatus }}</td>
                    
                    <td class="tw-font-mono text-end">{{ item.payouts|number_format }}</td>
                    <td class="tw-font-mono text-end">{{ item.value|string|format_currency('GBP') }}</td>
                    <td class="tw-font-mono text-end">{{ item.shares|number_format }}</td>

                    <td class="tw-font-mono text-end">{{ item.investmentCount|number_format }}</td>
                    <td class="tw-font-mono text-end">{{ item.investmentValue|format_currency('GBP') }}</td>
                    <td class="tw-font-mono text-end">{{ item.investmentShares|number_format }}</td>

                    <td class="tw-font-mono text-end">{{ item.orderCount|number_format }}</td>
                    <td class="tw-font-mono text-end">{{ item.orderValue|format_currency('GBP') }}</td>
                    <td class="tw-font-mono text-end">{{ item.orderShares|number_format }}</td>

                    <td class="tw-font-mono text-end">{{ (item.assetid in divestmentBuyBacks|keys ? divestmentBuyBacks[item.assetid].count : 0)|number_format }}</td>
                    <td class="tw-font-mono text-end">{{ (item.assetid in divestmentBuyBacks|keys ? divestmentBuyBacks[item.assetid].value : 0)|string|format_currency('GBP') }}</td>
                    <td class="tw-font-mono text-end">{{ (item.assetid in divestmentBuyBacks|keys ? divestmentBuyBacks[item.assetid].shares : 0)|number_format  }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% endblock %}
    {% endembed %}

{% endblock page_content %}
