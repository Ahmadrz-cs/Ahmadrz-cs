{% extends 'admin/layouts/col_1_fluid.html.twig' %}

{% set backToRoute = 'admin_trade_system_porting_index' %}
{% set areaHeading = 'Trade System Porting Tools' %}
{% set mainHeading = 'Port Offering Documents' %}
{% set maturityLabel = 'alpha' %}

{% form_theme form with ['bootstrap_5_layout.html.twig'] only %}

{% block page_content %}

    {% embed 'admin/components/_bordered_section.html.twig' with {
        "sectionId": "port-offerings",
        "sectionTitle": "Port Offerings",
    } %}
        {% block sectionContent %}
        {{ include('admin/components/_alert.html.twig', {
            variant: "info",
            title: "Batch Size",
            message: "Defaults to 10. Will be clamped between 1 and 200, presets are available below. Click the batch size, then click 'Port' to port a non-default batch size.",
        }) }}

        <div class="d-flex gap-2">
            {% for batchSize in [1,10,25,50,100, 200] %}
                {{ include('admin/components/button_link.html.twig', {
                    linkProps: {
                        "text": batchSize,
                        "route": app.request.attributes.get('_route'),
                        "params": {'batchSize': batchSize},
                        "style": "btn-outline-dark text-nowrap",
                    },
                }) }}
            {% endfor %}
        </div>

        {{ form_start(form) }}
        {{ form_row(form.port) }}
        {{ form_end(form) }}

        {{ include('admin/components/_alert.html.twig', {
            variant: "info",
            title: "Documents to Port",
            message: "Only offering documents in first party offerings that have a tag and documentUrl will be ported. The unused createdById field is set to the asset ID after porting to mark it as ported",
        }) }}

        {{ include('admin/components/_kv_table.html.twig', {
            tableId: "aggregate-info",
            title: "Aggregate Summary",
            valueDefaultStyle: "tw-font-mono",
            kv: {
                "Max batch": app.request.query.all.batchSize ?? 10,
                "Count in batch": offeringDocs|length|number_format,
            }
        }) }}

        <table class="table table-bordered table-striped-columns" id="offering-doc-list">
            <thead>
                <tr>
                    <th>Offering Document Id</th>
                    <th>Offering Id</th>
                    <th>Asset Id</th>
                    <th>Asset Name</th>
                    <th>Inner Document Id</th>
                    <th>Filename</th>
                    <th>Type</th>
                    <th>Tag</th>
                    <th>Description</th>
                    <th>Url</th>
                </tr>
            </thead>
            <tbody>
                {% for entry in offeringDocs %}
                <tr>
                    <td><a href="{{ path('admin_offeringdocument_edit', { id: entry.id }) }}">#{{ entry.id }}</a></td>
                    <td><a href="{{ path('admin_offering_edit', { id: entry.offering.id }) }}">#{{ entry.offering.id }}</a></td>
                    <td><a href="{{ path('admin_product_dashboard', { id: entry.offering.asset.id }) }}">#{{ entry.offering.asset.id }}</a></td>
                    <td>{{ entry.offering.asset.name }}</td>
                    <td>{{ entry.document.id }}</td>
                    <td>{{ entry.document.filename }}</td>
                    <td>{{ entry.document.type }}</td>
                    <td>{{ entry.document.tag }}</td>
                    <td>{{ entry.document.description }}</td>
                    <td>{{ entry.document.documentUrl }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        
        {% endblock %}
    {% endembed %}

{% endblock page_content %}
