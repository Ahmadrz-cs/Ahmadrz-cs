{% extends 'admin/layouts/object_editor.html.twig' %}

{% set backToRoute = 'admin_monthend_settlement_manage' %}
{% set backToRouteParams = { id: transferOrder.id } %}
{% set areaHeading = 'Monthend - Investment Settlement' %}
{% set mainHeading = 'Edit Transfer' %}

{% block page_content %}

    {% if not workflow_can(transferOrder, 'approve') %}
        {{ include('admin/components/_alert.html.twig', {
            variant: "warning",
            message: "Editing is restricted outside draft mode",
        }) }}
    {% endif %}

    {% embed 'admin/components/_bordered_section.html.twig' with {
        "sectionId": "share-trade-information",
        "sectionTitle": "Share Trade Information",
        "linkActions": [
            {
                "text": "View Asset Wallet Balances (opens in new tab)",
                "route": "admin_asset_wallets_manage",
                "params": {asset: transferOrder.asset.id},
                "style": "btn-outline-dark",
                "newTab": true,
            },
        ]
    } %}
        {% block sectionContent %}
        {% set shareTrade = transferRequest.shareTrade  %}
        <div class="row g-3">
            {{ include('admin/components/stat.html.twig', {
                key: 'Asset',
                value: '#%s // %s (%s)'|format(transferOrder.asset.id, transferOrder.asset.name, transferOrder.asset.companyNumber),
                className: 'col-12 col-md-6'
            }) }}
            {{ include('admin/components/stat.html.twig', {
                key: 'Buyer',
                value: '#%s // %s'|format(shareTrade.buyOrder.user.id, shareTrade.buyOrder.user.username), 
                className: 'col-12 col-md-6',
            }) }}
            {{ include('admin/components/stat.html.twig', {
                key: 'Share Trade Id',
                value: shareTrade.id,
            }) }}
            {{ include('admin/components/stat.html.twig', {
                key: 'Trade Value',
                value: shareTrade.tradeValue|string|format_currency('GBP'),
            }) }}
            {{ include('admin/components/stat.html.twig', {
                key: 'Trade Shares',
                value: shareTrade.numberOfShares|number_format(0, '.', ','),
            }) }}
            {{ include('admin/components/stat.html.twig', {
                key: 'Share Price',
                value: shareTrade.pricePerShare|string|format_currency('GBP'),
            }) }}
        </div>
        {% endblock %}
    {% endembed %}

    {{ form_start(form) }}
    <div class="row ">
        <div class="col-sm-6">{{ form_row(form.debitWalletId) }}</div>
        <div class="col-sm-6">{{ form_row(form.creditWalletId) }}</div>
        <div class="col-12">{{ form_row(form.amount) }}</div>
        <div class="col-12">
            {{ form_row(form.description) }}
            <datalist id="{{ form.description.vars.attr.list|default(form.description.vars.name) }}">
                <option value="{{ constant('App\\Service\\MonthEndService::DESCRIPTION_PRESETS')['settlement'] }}">
                <option value="{{ constant('App\\Service\\MonthEndService::DESCRIPTION_PRESETS')['stamp duty'] }}">
            </datalist>
        </div>
    </div>
    <div class="">
        <button class="btn btn-success" id="submit" type="submit">{% block saveActionText %}Save Changes{% endblock %}</button>
        <a class="btn btn-outline-secondary"
            href="{{ path('admin_monthend_settlement_manage', { id: transferOrder.id }) }}">{% block cancelActionText %}Discard Changes{% endblock %}</a>
    </div>
    {{ form_end(form) }}

{% endblock %}