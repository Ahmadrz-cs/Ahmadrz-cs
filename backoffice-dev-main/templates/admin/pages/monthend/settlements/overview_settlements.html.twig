{% extends 'admin/layouts/monthend.html.twig' %}

{% set areaHeading = 'Monthend' %}
{% set mainHeading = 'Settlements Overview' %}

{% form_theme form with ['bootstrap_5_layout.html.twig'] only %}

{% block page_content %}

    {% include 'admin/components/_horizontal_nav_btn_group.html.twig' with {
        'autodetectActive': true,
        'links': {
            navId: 'settlement-order-filter',
            navLabel: 'settlement-filter-options',
            linkDefinitions: [
                {
                    route: 'admin_monthend_overview_settlements',
                    params: {},
                    text: 'Pending Settlements',
                },
                {
                    route: 'admin_monthend_overview_settlements_list',
                    params: {},
                    text: 'All Settlements',
                },
            ]
	    }
    } only %}

    {% embed 'admin/components/_bordered_section.html.twig' with {
        "sectionId": "pending-settlements",
        "sectionTitle": "Pending Settlements",
        "linkActions": [
            {
				"text": "Create Settlement",
				"route": "admin_monthend_settlement_create",
				"params": {},
				"style": "btn-success",
				"roleRequired": "ROLE_OPERATIONS",
			},
        ]
    } %}
        {% block sectionContent %}
        {{ include('admin/components/_alert.html.twig', {
            variant: "info",
            message: "Default search range are investments from previous calendar month. Change this if you need to adjust the search range.",
        }) }}
        {{ form_start(form) }}
            <section class="row ">
                <div class="col-sm-6">{{ form_row(form.dateStart) }}</div>
                <div class="col-sm-6">{{ form_row(form.dateEnd) }}</div>
                <div class="col-12">
                    <button type="submit" id="submit" class="btn-primary btn">Apply Filters</button>
                    <a href="{{ app.request.pathinfo }}" class="btn-secondary btn">Reset to Defaults</a>
                </div>
            </section>
        {{ form_end(form) }}
        <div class="row g-3">
            {{ include('admin/components/stat.html.twig', {
                key: 'Total to Settle',
                value: summary.prefunding.count + summary.retailFirstParty.count + summary.retailRelisted.count,
            }) }}
            {{ include('admin/components/stat.html.twig', {
                key: 'Prefunding',
                value: summary.prefunding.count,
            }) }}
            {{ include('admin/components/stat.html.twig', {
                key: 'Retail First Party',
                value: summary.retailFirstParty.count,
            }) }}
            {{ include('admin/components/stat.html.twig', {
                key: 'Retail Relisted',
                value: summary.retailRelisted.count,
            }) }}
        </div>
        <div class="table-responsive">
            <table class="table" id="asset-settlement-list">
                <thead>
                    <tr>
                        <th>Actions</th>
                        <th>Asset</th>
                        <th class="text-end">Investments to settle</th>
                    </tr>
                </thead>
                <tbody>
                    {% for assetId, shareTrades in summary.assetSummary %}
                    <tr>
                        <td>
                            <a class="btn btn-outline-dark" href="{{ path('admin_monthend_asset_dashboard', { id: assetId }) }}">
                                Go to Asset Monthend Dashboard
                            </a>
                        </td>
                        <td>
                            <a href="{{ path('admin_product_dashboard', { id: assetId }) }}">
                                #{{ assetId }} // {{ shareTrades[0].buyOrder.asset.name }}
                                ({{ shareTrades[0].buyOrder.asset.companyNumber }})
                            </a>
                        </td>
                        <td class="text-end tw-tabular-nums">{{ shareTrades|length|default('0') }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% endblock %}
    {% endembed %}

{% endblock page_content %}