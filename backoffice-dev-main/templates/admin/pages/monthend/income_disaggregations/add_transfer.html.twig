{% extends 'admin/layouts/object_editor.html.twig' %}

{% set backToRoute = 'admin_monthend_income_disaggregation_manage' %}
{% set backToRouteParams = { id: transferOrder.id } %}
{% set areaHeading = 'Monthend - Income Disaggregation' %}
{% set mainHeading = 'Add Transfer' %}

{% block page_content %}

    <div class="row g-3">

        <div class="col-12">
            {% embed 'admin/components/_bordered_section.html.twig' with {
                "sectionId": "guidelines",
                "sectionTitle": "Guidelines",
                "linkActions": []
            } %}
                {% block sectionContent %}
                <div class="row g-3">
                    {{ include('admin/components/stat.html.twig', {
                        key: 'Asset',
                        value: '#%s // %s (%s)'|format(asset.id, asset.name, asset.companyNumber),
                        className: 'col-md-6'
                    }) }}
                    {{ include('admin/components/stat.html.twig', {
                        key: 'Asset Valuation',
                        value: '£' ~ asset.fundingGoal|number_format(2, '.', ','),
                        className: 'col-md-6'
                    }) }}
                </div>
                <section>
                    <h4 class="fw-bold h5 ">Wallet Balances</h4>
                    <div class="table-responsive">
                        <table class="table table-striped" id="wallet-balances">
                            <thead>
                                <tr>
                                    <th>Id</th>
                                    <th>Name</th>
                                    <th>Description</th>
                                    <th class="text-end">Balance (£)</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for name, wallet in walletBalances|default([]) %}
                                    <tr data-object-id="{{ wallet.walletId }}">
                                        <td>{{ wallet.walletId }}</td>
                                        <td>{{ name|title }}</td>
                                        <td>{{ wallet.description }}</td>
                                        <td class="text-end tw-tabular-nums">{{ wallet.balance|number_format(2, '.', ',') }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </section>
                {% endblock %}
            {% endembed %}
        </div>
        {% embed 'admin/components/_alert.html.twig' with {
            variant: "notice",
            title: "Which wallet to transfer to?",
        } %}
            {% block message %}
                <ul>
                    <li><span class="fw-bold">Settlement/Actual</span> wallet is recommended under the classic 2-wallet (hold and actual/main) system. Referred to as the <span class="fw-bold">settlement</span> wallet under the new wallet system.</li>
                    <li><span class="fw-bold">Deposit</span> wallet is recommended under the new wallet system.</li>
                </ul>
            {% endblock message %}
        {% endembed %}
        <div class="col-12">
            {{ form_start(form) }}
            <div class="row">
                <div class="col-sm-6">{{ form_row(form.debitWalletId) }}</div>
                <div class="col-sm-6">{{ form_row(form.creditWalletId) }}</div>
                <div class="col-12">{{ form_row(form.amount) }}</div>
                <div class="col-12">
                    {{ form_row(form.description) }}
                    <datalist id="{{ form.description.vars.attr.list|default(form.description.vars.name) }}">
                        {% for descriptionOption in constant('App\\Service\\MonthEndService::DESCRIPTION_PRESETS') %}
                            <option value="{{ descriptionOption }}">
                        {% endfor %}
                    </datalist>
                </div>
            </div>
            <div class="">
                <button class="btn btn-success" id="submit" type="submit">{% block saveActionText %}Add Transfer{% endblock %}</button>
                <a class="btn btn-outline-secondary"
                    href="{{ path('admin_monthend_income_disaggregation_search', { id: transferOrder.id }) }}">{% block cancelActionText %}Cancel{% endblock %}</a>
            </div>
            {{ form_end(form) }}
        </div>
    </div>

{% endblock page_content %}