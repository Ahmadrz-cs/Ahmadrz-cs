{% embed 'admin/components/_bordered_section.html.twig' with {
    "sectionId": "investment-settlements",
    "sectionTitle": "Investment Settlements",
    "linkActions": []
} %}
    {% block sectionContent %}

    {% set aggregatedByMonth = {} %}
    {% for month, breakdown in settlementsBreakdown|default([]) %}
        {% set aggregatedByMonth = aggregatedByMonth|merge({ 
            (month) : { 
                'count': activity.settlements[(month)]|length,
