{% extends 'admin/layouts/monthend.html.twig' %}

{% set areaHeading = 'Monthend' %}
{% set mainHeading = 'Share Transfers' %}
{% set maturityLabel = 'beta' %}

{% block page_content %}

    {% include 'admin/components/_horizontal_nav_btn_group.html.twig' with {
        'autodetectActive': true,
        'links': {
            navId: 'share-transfer-order-filter',
            navLabel: 'share-transfer-filter-options',
            linkDefinitions: [
                {
                    route: 'admin_monthend_overview_share_transfers',
                    params: {},
                    text: 'Pending Share Transfers',
                },
                {
                    route: 'admin_monthend_share_transfers_list',
                    params: {},
                    text: 'All Share Transfers',
                },
            ]
	    }
    } only %}

    {% embed 'admin/components/_bordered_section.html.twig' with {
        "sectionId": "share-transfer-orders",
        "sectionTitle": "All Share Transfer Orders",
        "linkActions": [
            {
                "text": "Create Share Transfer",
                "route": "admin_monthend_share_transfers_create",
                "params": {},
                "style": "btn-success",
                "roleRequired": "ROLE_OPERATIONS",
            },
        ]
    } %}
        {% block sectionContent %}
            {{ include('admin/components/pagerfanta_meta_slim.html.twig', {
                list: objects
            }) }}
            <div class="table-responsive">
                <table class="table" id="share-transfer-order-list">
                    <thead>
                        <tr>
                            <th>Actions</th>
                            <th>Id</th>
                            <th>Asset</th>
                            <th>Description</th>
                            <th>Related Monthend (Filing Date)</th>
                            <th>Period</th>
                            <th class="text-end">Shares</th>
                            <th class="text-end">Transfers</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for shareTransferOrder in objects|default([]) %}
                            {% set totalShares = shareTransferOrder.shareTransfers|reduce((carry, v) => carry + v.shares) %}
                            <tr>
                                <td>
                                    <a class="btn btn-outline-primary" href="{{ path('admin_monthend_share_transfers_manage', { id: shareTransferOrder.id }) }}">
                                        {%- if is_granted('ROLE_OPERATIONS') %}Manage{% else %}View
                                        {% endif -%}
                                    </a>
                                </td>
                                <td>{{ shareTransferOrder.id }}</td>
                                <td><a href="{{ path('admin_product_dashboard', {
                                        id: shareTransferOrder.asset.id
                                    }) }}">#{{ shareTransferOrder.asset.id}}
                                    // {{ shareTransferOrder.asset.name }} ({{ shareTransferOrder.asset.companyNumber }})</a>
                                </td>
                                <td>{{ shareTransferOrder.description }}</td>
                                <td>{{ shareTransferOrder.scheduledFor|date('Y-m-d') }}</td>
                                <td>{{ shareTransferOrder.periodStart|date('Y-m-d') }} - {{ shareTransferOrder.periodEnd|date('Y-m-d') }}</td>
                                <td class="text-end tw-tabular-nums">{{ totalShares|number_format(0, '.', '') }}</td>
                                <td class="text-end tw-tabular-nums">{{ shareTransferOrder.shareTransfers|length }}</td>
                                <td>{{ shareTransferOrder.status.value|capitalize|replace({'_':'-'}) }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endblock %}
    {% endembed %}

{% endblock page_content %}
