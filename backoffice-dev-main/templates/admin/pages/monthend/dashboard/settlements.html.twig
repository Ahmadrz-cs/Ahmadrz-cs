{% extends 'admin/pages/monthend/dashboard/_dashboard.html.twig' %}

{% block dashboard_content %}

    <div class="row g-3">

        {# <div class="col-12">
            {% embed 'admin/components/_bordered_section.html.twig' with {
                "sectionId": "investments-to-settle",
                "sectionTitle": "Investments To Settle",
                "linkActions": [
                    {
                        "text": "View Investments to Settle",
                        "route": "admin_investment_index",
                        "params": {
                            "assetId": asset.id,
                            "lifecycleStatus": ['approved']
                        },
                        "style": "btn-outline-primary",
                        "newTab": true,
                    },
                ]
            } %}
                {% block sectionContent %}
                <div class="row g-3">
                    {{ include('admin/components/stat.html.twig', {
                        key: 'Investments to Settle',
                        value: investmentsToSettle|length,
                    }) }}
                </div>
                {% endblock %}
            {% endembed %}
        </div> #}

        {% if currentSettlement is not empty %}

        {% set transfersCompletedList = currentSettlement.transfers|filter(p => p.status == constant('App\\Entity\\TransferRequest::STATE_COMPLETE')) %}
        {% set originalTotal = currentSettlement.transfers|reduce((carry, v) => carry + v.amount) %}
        {% set completedTotal = transfersCompletedList|reduce((carry, v) => carry + v.amount) %}

        <div class="col-12">
            {% embed 'admin/components/_bordered_section.html.twig' with {
                "sectionId": "current-monthend",
                "sectionTitle": "Current Monthend",
                "linkActions": [
                    {
                        "text": "View Current Monthend",
                        "route": "admin_monthend_settlement_manage",
                        "params": {"id": currentSettlement.id},
                        "style": "btn-outline-primary",
                    },
                ]
            } %}
                {% block sectionContent %}
                <div class="row">
                    {{ include('admin/components/stat.html.twig', {
                        key: 'Current Monthend',
                        value: currentSettlement.scheduledFor|date('Y-m-d'),
                    }) }}
                    {{ include('admin/components/stat.html.twig', {
                        key: 'Status',
                        value: currentSettlement.status|capitalize|replace({'_':'-'}),
                    }) }}
                    {{ include('admin/components/stat.html.twig', {
                        key: 'Transfers Completed',
                        value: transfersCompletedList|length
                            ~ '/' ~ currentSettlement.transfers|length
                    }) }}
                    {{ include('admin/components/stat.html.twig', {
                        key: 'Total Transferred (£)',
                        value: completedTotal|number_format(2, '.', ',') ~ '/' ~ originalTotal|number_format(2, '.', ',')
                    }) }}
                </div>
                {% endblock %}
            {% endembed %}
        </div>

        {% endif %}

        <div class="col-12">
            {% embed 'admin/components/_bordered_section.html.twig' with {
                "sectionId": "transfer-orders",
                "sectionTitle": "All Settlement Orders",
                "linkActions": [
                    {
                        "text": "Create Settlement",
                        "route": "admin_monthend_settlement_create",
                        "params": {assetId: asset.id},
                        "style": "btn-success",
                        "roleRequired": "ROLE_OPERATIONS",
                    },
                ]
            } %}
                {% block sectionContent %}
                <div class="row">
                    <div class="col-sm-6">{{ pagerfanta(transferOrders, 'twitter_bootstrap4') }}</div>
                    <section class="col-sm-6 mb-3 d-flex justify-content-end">
                        <span class="border rounded-2 d-inline-block p-2 me-1" id="list-meta-results">{{ transferOrders.count()|number_format(0, '.', ',') }} Results</span>
                        <span class="border rounded-2 d-inline-block p-2" id="list-meta-page">{{ transferOrders.getNbPages()|number_format(0, '.', ',') }} Pages</span>
                    </section> 
                </div>
                <div class="table-responsive">
                    <table class="table" id="transfer-order-list">
                        <thead>
                            <tr>
                                <th>Actions</th>
                                <th>Id</th>
                                <th>Description</th>
                                <th>Scheduled For</th>
                                <th>Transfers</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for transferOrder in transferOrders|default([]) %}
                                <tr>
                                    <td>
                                        <a class="btn btn-outline-primary"
                                            href="{{ path('admin_monthend_settlement_manage', { id: transferOrder.id }) }}">
                                            {%- if is_granted('ROLE_OPERATIONS') %}Manage{% else %}View
                                            {% endif -%}
                                        </a>
                                    </td>
                                    <td>{{ transferOrder.id }}</td>
                                    <td>{{ transferOrder.description }}</td>
                                    <td>{{ transferOrder.scheduledFor|date('Y-m-d', false) }}</td>
                                    <td>{{ transferOrder.transfers|length }}</td>
                                    <td>{{ transferOrder.status|capitalize|replace({'_':'-'}) }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% endblock %}
            {% endembed %}
        </div>
    </div>

{% endblock dashboard_content %}