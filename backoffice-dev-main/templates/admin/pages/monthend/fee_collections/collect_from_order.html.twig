{% extends 'admin/layouts/col_1.html.twig' %}

{% set backToRoute = 'admin_monthend_fee_collection_income_deposit_list' %}
{% set backToRouteParams = { id: transferOrder.id } %}
{% set areaHeading = 'Monthend - Fee Collection' %}
{% set mainHeading = 'Setup Transfers' %}

{% form_theme form with ['bootstrap_5_layout.html.twig'] only %}

{% set originalTotal = collectFromOrder.transfers|reduce((carry, v) => carry + v.amount) %}
{% set walletIds = collectFromOrder.transfers|map(t => t.creditWalletId) %}

{% block page_content %}

    {{ include('admin/components/_alert.html.twig', {
        variant: "warning",
        message: "This generator works best if you are using the legacy/single wallet system and the income disaggregation tool to deposit/allocate income. For assets using the multi wallet system, you should add transfers with alternative methods as fees are provisioned into the expenses wallet and therefore no longer in the actual/deposit wallet.",
    }) }}

    {% embed 'admin/components/_bordered_section.html.twig' with {
        "sectionId": "transfer-generation-preview",
        "sectionTitle": "Generate Fee Collection Transfers",
        "linkActions": []
    } %}
        {% block sectionContent %}
        {# {% embed 'admin/components/_alert.html.twig' with {
            variant: "info",
            title: "Transfer Order Requirements",
        } %}
            {% block message %}
                <p>The following list only shows transfer orders that meet the following requirements:</p>
                <ul>
                    <li>Must be an income disaggregation order (for splitting aggregated gross income in the superadmin wallet into each asset's actual/main wallet</li>
                    <li>Must be completed</li>
                    <li>Must be in the same scheduled monthend</li>
                </ul>
            {% endblock message %}
        {% endembed %} #}

        {{ form_start(form, {attr: {class: "d-grid sm:tw-grid-cols-2 gap-4"}}) }}

            <section class="d-flex flex-column gap-3 border rounded-3 p-3 p-lg-4" id="setup-step-1">
                <h4 class="fw-bold fs-5">Step 1: Preview Fee to Collect</h4>
                {{ form_row(form.percentageCut) }}
                <datalist id="{{ form.feeDescription.vars.attr.list|default(form.feeDescription.vars.name) }}">
                    <option value="{{ constant('App\\Service\\MonthEndService::DESCRIPTION_PRESETS')['management'] }}">
                </datalist>
                <div class="d-flex flex-wrap gap-2 mt-auto">
                    {{ form_widget( form.preview, { 'attr': {'class': 'btn-primary'} } ) }}
                    {{ include('admin/components/button_link.html.twig', {
                        linkProps: {
                            "text": "Cancel",
                            "route": "admin_monthend_fee_collection_manage",
                            "params": {id: transferOrder.id},
                            "style": "btn-outline-secondary text-nowrap",
                        },
                    }) }}
                    {{ include('admin/components/button_link.html.twig', {
                        linkProps: {
                            "text": "Reset Criteria to Default",
                            "route": app.request.attributes.get('_route'),
                            "params": {
                                id: transferOrder.id,
                                collectFromOrder: collectFromOrder.id
                            },
                            "style": "btn-outline-secondary text-nowrap",
                        },
                    }) }}
                </div>
            </section>

            <section class="d-flex flex-column gap-3 border rounded-3 p-3 p-lg-4" id="setup-step-2">
                <h4 class="fw-bold fs-5">Step 2: Generate Fee Collection Transfers</h4>
                {{ include('admin/components/_alert.html.twig', {
                    variant: "info",
                    message: "Generated transfers will go from the original transfer's credited wallet to the fee wallet (or superadmin wallet if no fee wallet configured). For the legacy/single wallet system, this will be the actual/main wallet. For the multi wallet system, this will be the deposit wallet.",
                }) }}
                {{ form_row(form.feeDescription) }}
                {{ form_row(form.feeWalletId) }}
                <div class="mt-auto">
                    {{ form_widget( form.generate, { 'attr': {'class': 'btn-success mt-3'} } ) }}
                </div>
            </section>

            {{ form_rest(form) }}
        {{ form_end(form) }}

        <div class="row g-3">
            <h4 class="fw-bold fs-5">Fee Collection Preview</h4>
            {{ include('admin/components/stat.html.twig', {
                key: 'Number of Transfers',
                value: collectFromOrder.transfers|length,
            }) }}
            {{ include('admin/components/stat.html.twig', {
                key: 'Estimated Total Fees to Collect',
                value: '£' ~ (originalTotal * form.vars.value.percentageCut)|number_format(2, '.', ','),
            }) }}
            {{ include('admin/components/stat.html.twig', {
                key: 'Fee Collection Order',
                value: transferOrder.id,
            }) }}
            {{ include('admin/components/stat.html.twig', {
                key: 'Collecting from Order',
                value: collectFromOrder.id,
            }) }}
        </div>

        <table class="table table-striped datatable" id="transfers-preview-list">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Original Description</th>
                    <th>Transfer From Wallet</th>
                    <th>Original Amount (£)</th>
                    <th>Fee to Collect (£)</th>
                </tr>
            </thead>
            <tbody>
                {% for transfer in collectFromOrder.transfers|default([]) %}
                    <tr data-object-id="{{ transfer.id }}">
                        <td data-field="transferId">{{ transfer.id }}</td>
                        <td data-field="description">{{ transfer.description }}</td>
                        <td data-field="debitWalletId">{{ transfer.creditWalletId }}</td>
                        <td data-field="amount">{{ transfer.amount|number_format(2, '.', ',') }}</td>
                        <td data-field="fee">{{ (transfer.amount * form.vars.value.percentageCut)|number_format(2, '.', ',') }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
        {% endblock %}
    {% endembed %}

{% endblock page_content %}