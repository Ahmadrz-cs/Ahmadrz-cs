{% extends 'admin/layouts/col_1.html.twig' %}

{% set backToRoute = 'admin_monthend_fee_collection_index' %}
{% set areaHeading = 'Monthend' %}
{% set mainHeading = 'Fee Collection' %}

{% set transfersList = transferOrder.transfers %}
{% set transfersCompletedList = transferOrder.transfers|filter(p => p.status == constant('App\\Entity\\TransferRequest::STATE_COMPLETE')) %}
{% set originalTotal = transfersList|reduce((carry, v) => carry + v.amount) %}
{% set completedTotal = transfersCompletedList|reduce((carry, v) => carry + v.amount) %}

{% block page_content %}

    {{ include('admin/pages/monthend/order_actions.html.twig', {
        order: transferOrder,
        originalTotal: originalTotal
    }) }}
    
    {{ include('admin/pages/monthend/_validation_issues_warning.html.twig') }}

    {% if transfersList is not empty
        and workflow_can(transferOrder, constant('App\\Entity\\AbstractOrder::TRANSITION_APPROVE')) %}

        {% embed 'admin/components/_alert.html.twig' with {
            variant: "warning",
            title: "Check Wallet Balances",
            elementId: "wallet-balance-prompt",
        } %}
            {% block message %}
                <p>You should check that the asset wallets have enough funds to pay the relisting fee before approving the order.</p>
                {{ include('admin/components/button_link.html.twig', {
                    linkProps: {
                        "text": "Check Wallet Balances",
                        "route": "admin_monthend_wallet_checker",
                        "params": {id: transferOrder.id},
                        "style": "btn-dark",
                    },
                }) }}
            {% endblock message %}
        {% endembed %}

    {% endif %}

    {% if feeGuess is not empty and feeGuess != transferOrder.description %}

        {% embed 'admin/components/_alert.html.twig' with {
            variant: "notice",
            title: "Edit Order Description",
            elementId: "description-suggestion",
        } %}
            {% block message %}
                <p>Based on the transfers in this order, you may want to update the order description to better describe what the fee collection order is for. Suggested description: "{{ feeGuess }}"</p>
                <div class="d-flex flex-wrap gap-2">
                    {{ include('admin/components/button_link.html.twig', {
                        linkProps: {
                            "text": "Apply Suggested Description",
                            "route": "admin_monthend_fee_collection_generate_description",
                            "params": {id: transferOrder.id},
                            "style": "btn-dark",
                        },
                    }) }}
                    {{ include('admin/components/button_link.html.twig', {
                        linkProps: {
                            "text": "Edit Order",
                            "route": "admin_monthend_fee_collection_edit",
                            "params": {id: transferOrder.id},
                            "style": "btn-outline-secondary",
                            "roleRequired": "ROLE_OPERATIONS",
                        },
                    }) }}
                </div>
            {% endblock message %}
        {% endembed %}

    {% endif %}


    {% if otherMonthendOrders is not empty %}
    
        {% embed 'admin/components/_bordered_section.html.twig' with {
            "sectionId": "existing-order-warning",
            "sectionTitle": "Similar Fee Collection Already Exists",
            "sectionStyle": "border rounded-3 p-4 border-warning",
        } %}
            {% block sectionContent %}
            {{ include('admin/components/_alert.html.twig', {
                variant: "warning",
                message: "There is already a fee collection for this monthend period. You can ignore this warning if additional fee collections are intentional.",
            }) }}
            <div class="overflow-auto">
                <table class="table" id="">
                    <thead>
                        <tr>
                            <th>Actions</th>
                            <th>Id</th>
                            <th>Related Monthend</th>
                            <th>Description</th>
                            <th>Transfers</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for transferOrder in otherMonthendOrders|default([]) %}
                            <tr data-transfer-order-id="{{ transferOrder.id }}">
                                <td>
                                    <a class="btn btn-outline-primary"
                                        href="{{ path('admin_monthend_fee_collection_manage', { id: transferOrder.id }) }}">
                                        View
                                    </a>
                                </td>
                                <td>{{ transferOrder.id }}</td>
                                <td>{{ transferOrder.scheduledFor|date('Y-m', false) }}</td>
                                <td>{{ transferOrder.description }}</td>
                                <td>{{ transferOrder.transfers|length }}</td>
                                <td>{{ transferOrder.status|capitalize|replace({'_':'-'}) }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% endblock %}
        {% endembed %}

    {% endif %}

    <div class="row g-3">

        <div class="col-lg-6">
            {% embed 'admin/components/_bordered_section.html.twig' with {
                "sectionId": "about-transfer",
                "sectionTitle": "About Transfer Order",
                "linkActions": [
                    {
                        "text": "Edit Order",
                        "route": "admin_monthend_fee_collection_edit",
                        "params": {id: transferOrder.id},
                        "style": "btn-outline-secondary",
                        "roleRequired": "ROLE_OPERATIONS",
                    },
                    {
                        "text": "Check Wallet Balances",
                        "route": "admin_monthend_wallet_checker",
                        "params": {id: transferOrder.id},
                        "style": "btn-outline-dark",
                    },
                    {
                        "text": "Configure Fee Wallets",
                        "route": "admin_app_setting",
                        "params": {},
                        "style": "btn-outline-dark",
                        "newTab": true,
                        "roleRequired": "ROLE_TECH_OPS",
                    },
                ]
            } %}
                {% block sectionContent %}
                <div class="row g-3">
                    {{ include('admin/components/stat.html.twig', {
                        key: 'Order Id',
                        value: transferOrder.id,
                        className: 'col-md-6'
                    }) }}
                    {{ include('admin/components/stat.html.twig', {
                        key: 'Scheduled Monthend',
                        value: transferOrder.scheduledFor|date('Y-m'),
                        className: 'col-md-6'
                    }) }}
                    {{ include('admin/components/stat.html.twig', {
                        key: 'Covering Period Between',
                        value: transferOrder.scheduledFor|date_modify('-1 month')|date('01 F Y') 
                            ~ ' - ' 
                            ~ transferOrder.scheduledFor|date_modify('-1 month')|date('t F Y'),
                        className: 'col-12',
                    }) }}
                    {# {{ include('admin/components/stat.html.twig', {
                        key: 'Fee Collection Wallet' ~ (isDedicatedFeeWallet ? '' : ' (Superadmin)'),
                        value: feeWallet,
                        className: 'col-md-6'
                    }) }} #}
                    {{ include('admin/components/stat.html.twig', {
                        key: 'Description',
                        value: transferOrder.description|default('-'),
                        className: 'col-12',
                        valueClassName: 'bg-light rounded-2 p-3'
                    }) }}
                </div>
                {{ include('admin/components/monthend/_available_fee_wallets.html.twig', {
                    feeWallets: feeWallets,
                    transfers: transferOrder.transfers
                }) }}
                {% endblock %}
            {% endembed %}
        </div>
        <div class="col-lg-6">
            {% embed 'admin/components/_bordered_section.html.twig' with {
                "sectionId": "order-status",
                "sectionTitle": "Order Status",
            } %}
                {% block customLinkActions %}
                    {{ include('admin/pages/transfer_order/_status_transitions.html.twig', {
                        additionalParams: { redirectRoute: 'admin_monthend_fee_collection_manage' }
                    }) }}
                {% endblock customLinkActions %}

                {% block sectionContent %}
                <div class="row g-3">
                    {{ include('admin/components/stat.html.twig', {
                        key: 'Status',
                        value: transferOrder.status|capitalize|replace({'_':'-'}),
                        className: 'col-md-6'
                    }) }}
                    {{ include('admin/components/stat.html.twig', {
                        key: 'Approved By',
                        value: transferOrder.approvedBy|default('-'),
                        className: 'col-12',
                        valueClassName: 'bg-light rounded-2 p-3'
                    }) }}
                    {{ include('admin/components/blame-timestamp.html.twig', {
                        object: transferOrder,
                    }) }}
                </div>
                {% endblock %}
            {% endembed %}
        </div>
        {# <div class="col-lg-6">
            {% embed 'admin/components/_bordered_section.html.twig' with {
                "sectionId": "about-asset",
                "sectionTitle": "About Asset",
                "linkActions": []
            } %}
                {% block sectionContent %}
                <div class="">
                    <a class="btn btn-outline-dark"
                        href="{{ path('admin_product_dashboard', {
                            id: transferOrder.asset.id,
                        }) }}">
                        View Asset Product
                    </a>
                    <a class="btn btn-outline-dark"
                        href="{{ path('admin_asset_wallets_manage', {
                            asset: transferOrder.asset.id,
                        }) }}">
                        View Wallet Balances
                    </a>
                </div>
                <div class="row g-3">
                    {{ include('admin/components/stat.html.twig', {
                        key: 'SPV Company Number',
                        value: transferOrder.asset.companyNumber,
                        className: 'col-md-6'
                    }) }}
                    {{ include('admin/components/stat.html.twig', {
                        key: 'Asset Valuation',
                        value: '£' ~ transferOrder.asset.fundingGoal|number_format(2, '.', ','),
                        className: 'col-md-6'
                    }) }}
                </div>
                {% endblock %}
            {% endembed %}
        </div> #}
        {# <div class="col-lg-6">
