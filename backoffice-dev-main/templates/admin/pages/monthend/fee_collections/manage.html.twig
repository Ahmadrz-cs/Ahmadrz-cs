        </div> #}
        <div class="col-12">
            {% embed 'admin/components/_bordered_section.html.twig' with {
                "sectionId": "transfers",
                "sectionTitle": "Transfers",
                "linkActions": [
                    {
                        "text": "Setup Transfers",
                        "route": "admin_monthend_fee_collection_setup",
                        "params": {id: transferOrder.id},
                        "style": "btn-dark",
                        "roleRequired": "ROLE_OPERATIONS",
                        "render": transferOrder.status == 'draft',
                    },
                    {
                        "text": "Add Transfer",
                        "route": "admin_monthend_fee_collection_search",
                        "params": {id: transferOrder.id},
                        "style": "btn-outline-dark",
                        "roleRequired": "ROLE_OPERATIONS",
                        "render": transferOrder.status == 'draft',
                    },
                    {
                        "text": "Clear All Transfers",
                        "route": "admin_transfer_order_clear_transfers",
                        "params": {
                            id: transferOrder.id,
                            redirectRoute: 'admin_monthend_fee_collection_manage',
                        },
                        "style": "btn-outline-danger",
                        "roleRequired": "ROLE_OPERATIONS",
                        "render": transferOrder.status == 'draft',
                    },
                    {
                        "text": "Export Transfers List",
                        "route": "admin_transfer_order_transfers_export",
                        "params": {id: transferOrder.id},
                        "style": "btn-outline-dark",
                    },
                ]
            } %}
                {% block sectionContent %}
                <div class="row g-3">
                    {# {{ include('admin/components/stat.html.twig', {
                        key: 'Wallet Balance (£)',
                        value: depositWalletBalance|number_format(2, '.', ',')
                    }) }} #}
                    {{ include('admin/components/stat.html.twig', {
                        key: 'Transfers Completed',
                        value: transfersCompletedList|length
                            ~ '/' ~ transferOrder.transfers|length
                    }) }}
                    {{ include('admin/components/stat.html.twig', {
                        key: 'Total Transferred (£)',
                        value: completedTotal|number_format(2, '.', ',') ~ '/' ~ originalTotal|number_format(2, '.', ',')
                    }) }}
                    {% set lastTransfer = transfersCompletedList|sort((a, b) => a.updatedAt <=>
                    b.updatedAt)|last %}
                    {{ include('admin/components/stat.html.twig', {
                        key: 'Most Recently Completed',
                        value: lastTransfer is empty ? "-" : lastTransfer.updatedAt|date('Y-m-d H:i:s (P)'),
                    }) }}
                </div>
                <div class="table-responsive">
                    <table class="table table-striped datatable" id="transfers-list">
                        <thead>
                            <tr>
                                <th>Actions</th>
                                <th>Asset</th>
                                <th>Transfer From</th>
                                <th>Transfer To</th>
                                <th>Description</th>
                                <th class="text-end">Amount (£)</th>
                                <th class="text-end">Proportion (%)</th>
                                <th>Updated</th>
                                <th>Status</th>
                                <th>Transaction Reference</th>
                                
                            </tr>
                        </thead>
                        <tbody>
                            {% for transferRequest in transferOrder.transfers|default([]) %}
                                <tr data-object-id="{{ transferRequest.id }}">
                                    <td>
                                        <div class="d-flex flex-wrap gap-1">
                                            {% if is_granted('ROLE_FINANCIAL_OPS')
                                                and workflow_can(transferRequest, constant('App\\Entity\\TransferRequest::TRANSITION_TRANSFER'))
                                                and workflow_can(transferOrder, constant('App\\Entity\\AbstractOrder::TRANSITION_RUN'))
                                            %}
                                                {{ include('admin/components/button_link.html.twig', {
                                                    linkProps: {
                                                        "text": "Transfer Single",
                                                        "route": 'admin_transfer_request_run',
                                                        "params": {
                                                                id: transferRequest.id,
                                                                redirectRoute: 'admin_monthend_fee_collection_manage',
                                                            },
                                                        "style": "btn-primary text-nowrap",
                                                    },
                                                }) }}
                                            {% endif %}
                                            {% if is_granted('ROLE_OPERATIONS') %}
                                                {{ include('admin/components/button_link.html.twig', {
                                                    linkProps: {
                                                        "text": "Edit",
                                                        "route": 'admin_transfer_request_edit',
                                                        "params": {
                                                            id: transferRequest.id,
                                                            restricted: 1,
                                                        },
                                                        "style": "btn-outline-primary text-nowrap",
                                                    },
                                                }) }}

                                                {% if workflow_can(transferOrder, constant('App\\Entity\\AbstractOrder::TRANSITION_APPROVE')) %}
                                                    {{ include('admin/components/button_link.html.twig', {
                                                        linkProps: {
                                                            "text": "Delete",
                                                            "route": 'admin_transfer_request_delete',
                                                            "params": {
                                                                id: transferRequest.id,
                                                                redirectRoute: 'admin_monthend_fee_collection_manage',
                                                            },
                                                            "style": "btn-outline-danger text-nowrap",
                                                            "dangerous": true,
                                                        },
                                                    }) }}
                                                {% endif %}
                                            {% endif %}

                                            {% if transferRequest.transaction is not null %}
                                                {{ include('admin/components/button_link.html.twig', {
                                                    linkProps: {
                                                        "text": "View Transaction",
                                                        "route": 'admin_transactions_view',
                                                        "params": {id: transferRequest.transaction.id},
                                                        "style": "btn-outline-dark text-nowrap",
                                                    },
                                                }) }}
                                            {% endif %}
                                        </div>
                                    </td>
                                    <td data-field="asset">
                                        {% if transferRequest.asset is not null %}
                                            <a href="{{ path('admin_product_dashboard', {
                                                id: transferRequest.asset.id
                                            }) }}">#{{ transferRequest.asset.id }} 
                                            // {{ transferRequest.asset.name }}
                                            ({{ transferRequest.asset.companyNumber }})</a>
                                        {% else %}N/A{% endif %}
                                    </td>
                                    <td class="tw-text-sm tw-font-mono" data-field="debitWalletId">{{ transferRequest.debitWalletId }}</td>
                                    <td class="tw-text-sm tw-font-mono" data-field="creditWalletId">{{ transferRequest.creditWalletId }}</td>
                                    <td data-field="description">{{ transferRequest.description }}</td>
                                    <td class="text-end tw-tabular-nums" data-field="amount">{{ transferRequest.amount|number_format(2, '.', ',') }}</td>
                                    <td class="text-end tw-tabular-nums">{{ (transferRequest.amount * 100 / max(originalTotal, 0.01))|number_format(3, '.', ',') }}</td>
                                    <td>{{ transferRequest.updatedAt|date('Y-m-d H:i:s') }}</td>
                                    <td>{{ transferRequest.status|capitalize }}{% if transferRequest.statusInfo %} ({{ transferRequest.statusInfo }}){% endif %}</td>
                                    <td class="tw-text-sm tw-font-mono">{{ transferRequest.transaction.externalId|default('N/A') }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% endblock %}
            {% endembed %}
        </div>
    </div>

{% endblock page_content %}