{% extends 'admin/layouts/object_editor.html.twig' %}

{% set backToRoute = exitRoute ?? 'admin_monthend_fee_collection_search' %}
{% set backToRouteParams = { id: transferOrder.id } %}
{% set areaHeading = 'Monthend - Fee Collection' %}
{% set mainHeading = 'Add Transfer' %}

{% block page_content %}

    <div class="row g-3">

        <div class="col-12">
            {% embed 'admin/components/_bordered_section.html.twig' with {
                "sectionId": "guidelines",
                "sectionTitle": "Guidelines",
                "linkActions": [
                    {
                        "text": "View Asset Wallet Balances",
                        "route": "admin_asset_wallets_manage",
                        "params": {asset: asset.id},
                        "style": "btn-outline-dark",
                        "newTab": true,
                    },
                    {
                        "text": "Configure Fee Wallets",
                        "route": "admin_app_setting",
                        "params": {},
                        "style": "btn-outline-dark",
                        "newTab": true,
                        "roleRequired": "ROLE_TECH_OPS",
                    },
                ]
            } %}
                {% block sectionContent %}
                    <div class="row g-3">
                        {{ include('admin/components/stat.html.twig', {
                        key: 'Asset',
                        value: '#%s // %s (%s)'|format(asset.id, asset.name, asset.companyNumber),
                        className: 'col-md-6'
                    }) }}
                        {{ include('admin/components/stat.html.twig', {
                        key: 'Asset Valuation',
                        value: '£' ~ asset.fundingGoal|number_format(2, '.', ','),
                        className: 'col-md-6'
                    }) }}
                    </div>
                    {{ include('admin/components/monthend/_available_fee_wallets.html.twig', {
                    feeWallets: feeWallets
                }) }}
                {% endblock %}
            {% endembed %}
        </div>
        {% embed 'admin/components/_alert.html.twig' with {
            variant: "info",
            title: "Which wallet to transfer to?",
        } %}
            {% block message %}
                <ul>
                    <li>
                        <span class="fw-bold">Superadmin</span>
                        wallet is available if no dedicated fee wallet is configured.</li>
                    <li>
                        <span class="fw-bold">Yielders Fee</span>
                        wallet is recommended where available since it segregates the fee revenue funds.</li>
                    <li>
                        <span class="fw-bold">YPML Fee</span>
                        wallet is for segregating fees associated with Yielders Property Management Limited (YPML) from regular Yielders activity. This wallet can be configured from the application settings if you're an admin (or techops)</li>
                </ul>
            {% endblock message %}
        {% endembed %}
        <div class="col-12">
            {{ form_start(form) }}
            <div class="row">
                <div class="col-sm-6">{{ form_row(form.debitWalletId) }}</div>
                <div class="col-sm-6">{{ form_row(form.creditWalletId) }}</div>
                <div class="col-12">{{ form_row(form.amount) }}</div>
                <div class="col-12">
                    {{ form_row(form.description) }}
                    {# <datalist id="{{ form.description.vars.attr.list|default(form.description.vars.name) }}">
                                            {% for descriptionOption in constant('App\\Service\\MonthEndService::DESCRIPTION_PRESETS') %}
                                                <option value="{{ descriptionOption }}">
                                            {% endfor %}
                                        </datalist> #}
                </div>
            </div>
            <div class="">
                <button class="btn btn-success" id="submit" type="submit">
                    {% block saveActionText %}Add Transfer
                    {% endblock %}
                </button>
                <a class="btn btn-outline-secondary" href="{{ path(exitRoute ?? 'admin_monthend_fee_collection_search', { id: transferOrder.id }) }}">
                    {% block cancelActionText %}Cancel
                    {% endblock %}
                </a>
            </div>
            {{ form_end(form) }}
        </div>
    </div>

{% endblock page_content %}
