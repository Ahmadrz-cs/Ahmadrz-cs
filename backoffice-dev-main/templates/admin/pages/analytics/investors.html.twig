{% extends 'admin/layouts/col_1.html.twig' %}

{% set backToRoute = 'admin_analytics_dashboard' %}
{% set areaHeading = 'Analytics' %}
{% set mainHeading = 'Investor Leaderboards' %}
{% set maturityLabel = 'beta' %}

{% form_theme form with ['bootstrap_5_layout.html.twig'] only %}

{% block page_content %}
    
    {{ include('admin/components/_prototype_warning.html.twig', {
        featureName: 'investor leaderboards'
    }) }}

    {% embed 'admin/components/_bordered_section.html.twig' with {
        "sectionId": 'leaderboard-configuration',
        "sectionTitle": 'Leaderboard Configuration',
    } %}
        {% block sectionContent %}
        <div class="row g-3">
            {{ include('admin/components/stat.html.twig', {
                key: 'Current Search Range',
                value: dateRange.start|date('Y-m-d') ~ ' <= X < ' ~ dateRange.end|date('Y-m-d'),
                className: 'col-md-6'
            }) }}
        </div>
        {{ form_start(form) }}
            <div class="row mt-3">
                <div class="col-sm-6">{{ form_row(form.metric) }}</div>
                <div class="col-sm-6">{{ form_row(form.month) }}</div>
            </div>
            <div class="mt-3">
                <button class="btn btn-primary" id="submit" type="submit">Apply Config</button>
                <a class="btn btn-outline-secondary"
                    href="{{ path('admin_analytics_investors') }}">Reset Config to Default</a>
            </div>
        {{ form_end(form) }}
        {% endblock %}
    {% endembed %}
        
    {% embed 'admin/components/_bordered_section.html.twig' with {
        "sectionId": 'leaderboard',
        "sectionTitle": 'Leaderboard',
    } %}
        {% block sectionContent %}
        {% if form.vars.data.metric == 'positions' %}
        <div class="mt-3 alert alert-info">
            Assets Invested (Positions) is across all time. The chosen month is ignored.
        </div>
        {% endif %}
        <table class="table mt-3 mb-0">
            <thead>
                <tr>
                    <th>User</th>
                    <th>Count</th>
                    <th>Value (£)</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                {% for entry in leaderboard %}
                <tr>
                    <td>#{{ entry.user }} // {{ userIdMap[entry.user] }}</td>
                    <td>{{ entry.count }}</td>
                    <td>{{ entry.value|number_format(2, '.', ',') }}</td>
                    <td>
                        <a class="btn btn-outline-primary"
                            target="_blank"
                            href="{{ path('admin_user_dashboard_statements', {
                            id: entry.user,
                            'month': form.vars.data.month|date('Y-m-d')
                        }) }}">View Monthly Statement</a>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% endblock %}
    {% endembed %}

{% endblock page_content %}
