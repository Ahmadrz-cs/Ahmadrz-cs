    <article class="col-xl-4 col-sm-6">
        <h4 class="mb-2">Yearly Relistings Count</h4>
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Year</th>
                    <th>Relisting Count</th>
                </tr>
            </thead>
            <tbody>
                {% for listing in relistingOverTimeYear %}
                <tr>
                    <td>{{ listing.year }}</td>
                    <td>{{ listing.count }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </article>
</section>

<section class="row">
    <h3 class="col-12 mb-4">User Breakdowns</h3>
    <article class="col-xl-4 col-sm-6">
        <h4 class="mb-2">Unique Investor Count</h4>
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Unique Investors</th>
                    <th>Settlement Date</th>
                </tr>
            </thead>
            <tbody>
                {% for investor in uniqueInvestors %}
                <tr>
                    <td>{{ investor.count }}</td>
                    <td>{{ investor.year }}-{{ investor.month }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </article>
    <article class="col-xl-4 col-sm-6">
        <h4 class="mb-2">Active Investors</h4>
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Users who logged in</th>
                </tr>
            </thead>
            <tbody>
                {% for item in activeUsers %}
                <tr>
                    <td>{{ (item.year ~ '-' ~ item.month)|date("Y-M") }}</td>
                    <td>{{ item.count }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </article>
    {# <article class="col-xl-4 col-sm-6">
        <h4 class="mb-2">Users Onboarded & Have Invested</h4>
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Invested Users</th>
                    <th>Non-Invested Users</th>
                </tr>
            </thead>
            <tbody>
                {% for user in onboardedInvested %}
                <tr>
                    <td>{{ user.username }}</td>
                    <td>{{ user.count }}-number of users</td>
