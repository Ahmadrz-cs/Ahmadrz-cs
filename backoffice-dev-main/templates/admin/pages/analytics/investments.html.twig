{% extends 'admin/layouts/analytics.html.twig' %}

{% set mainHeading = 'Investments' %}

{% block filters %}
    <div class="col-sm-6 col-md-4 col-xl-3">{{ form_row(form.createdAt_gte) }}</div>
    <div class="col-sm-6 col-md-4 col-xl-3">{{ form_row(form.createdAt_lt) }}</div>
{% endblock filters %}

{% block graph %}
    <canvas id="chartArea" data-chart={{ investments|json_encode }}></canvas>
{% endblock graph %}

{% block table %}
<div class="">
    <h4>Investment Count Over Time</h4>
    <table class="table table-striped table-bordered mb-0">
        <thead>
            <tr>
                <th>Date</th>
                <th>Investment Count</th>
            </tr>
        </thead>
        <tbody>
            {% for inv in investments %}
                <tr>
                    <td>{{ inv.date }}</td>
                    <td>{{ inv.count }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
<div class="">
    <h4>Investment Values Over Time</h4>
    <table class="table table-striped table-bordered mb-0">
        <thead>
            <tr>
                <th>Date</th>
                <th>Investments Total</th>
            </tr>
        </thead>
        <tbody>
            {% for inv in investments %}
                <tr>
                    <td>{{ inv.date }}</td>
                    <td>£{{ inv.total|number_format(2, '.', ',') }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock table %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('analyticsInvestmentsOverTime') }}
{% endblock javascripts %}
