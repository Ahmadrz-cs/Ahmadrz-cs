{% extends 'admin/layouts/filtered_list.html.twig' %}

{% set areaHeading = 'Transfer Orders' %}
{% set mainHeading = 'Transfer Orders List' %}
{% set baseTemplate = 'cms' %}

{% block createActions %}
    {% if is_granted('ROLE_OPERATIONS') %}
        <a class="btn btn-success" href="{{ path('admin_transfer_order_create') }}">Create Transfer Order</a>
    {% endif %}
    <a class="btn btn-outline-dark" href="{{ path('admin_transfer_order_export') }}">Export Transfer Orders</a>
{% endblock %}

{% block filterPresets %}
    <a href="{{ path('admin_transfer_order_index', { status: ['draft'] }) }}" class="btn btn-light">Draft</a>
    <a href="{{ path('admin_transfer_order_index', { status: ['in_progress', 'approved'] }) }}" class="btn btn-light">Ready To Run</a>
    <a href="{{ path('admin_transfer_order_index', { status: ['completed'] }) }}" class="btn btn-light">Completed</a>
{% endblock %}

{% block collapsibleFilters %}
    <div class="col-sm-6 col-md-4 col-xl-3">{{ form_row(form.id) }}</div>
    <div class="col-sm-6 col-md-4 col-xl-3">{{ form_row(form.assetId) }}</div>
    <div class="col-sm-6 col-md-4 col-xl-3">{{ form_row(form.assetName) }}</div>
    <div class="col-sm-6 col-md-4 col-xl-3">
        {% include 'admin/components/collapsible_field.html.twig' with {'formField': form.transferType} only %}
    </div>
    <div class="col-sm-6 col-md-4 col-xl-3">
        {% include 'admin/components/collapsible_field.html.twig' with {'formField': form.status} only %}
    </div>
{% endblock %}

{% block collapsibleFiltersRange %}
    <div class="col-sm-6 col-md-4 col-xl-3">{{ form_row(form.createdAt_gte) }}</div>
    <div class="col-sm-6 col-md-4 col-xl-3">{{ form_row(form.createdAt_lt) }}</div>
{% endblock %}

{% block table %}
    <table class="table table-striped" id="transfer-order-list">
        <thead>
            <tr>
                <th>Actions</th>
                <th>Id</th>
                <th>Type</th>
                <th>Asset</th>
                <th>Description</th>
                <th>Scheduled For</th>
                <th>Transfers</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            {% for transferOrder in objects|default([]) %}
                <tr>
                    <td>
                        {{ include('admin/components/button_link.html.twig', {
                            linkProps: {
                                "text": is_granted('ROLE_OPERATIONS') ? "Manage" : "View",
                                "route": 'admin_transfer_order_manage',
                                "params": {id: transferOrder.id},
                                "style": "btn-outline-dark text-nowrap",
                            },
                        }) }}
                    </td>
                    <td data-field="id">{{ transferOrder.id }}</td>
                    <td data-field="type">{{ transferOrder.transferType.value|capitalize }}</td>
                    <td data-field="asset">
                        {% if transferOrder.asset is not empty %}
                            <a href="{{ path('admin_asset_edit', { id: transferOrder.asset.id }) }}">
                                #{{ transferOrder.asset.id }}
                                //
                                {{ transferOrder.asset.name }}
                                ({{ transferOrder.asset.companyNumber }})
                            </a>
                        {% else %}
                            None
                        {% endif %}
                    </td>
                    <td data-field="description">{{ transferOrder.description }}</td>
                    <td data-field="scheduledFor">{{ transferOrder.scheduledFor|date('Y-m-d', false) }}</td>
                    <td data-field="transferCount">{{ transferOrder.transfers|length }}</td>
                    <td data-field="status">{{ transferOrder.status|capitalize|replace({'_':'-'}) }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}
