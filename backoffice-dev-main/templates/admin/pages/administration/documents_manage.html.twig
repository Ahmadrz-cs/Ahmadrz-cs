{% extends 'admin/layouts/col_1.html.twig' %}

{% set backToRoute = 'admin_administration_doc_dashboard' %}
{% set areaHeading = 'Maintenance Tools' %}
{% set mainHeading = doc_type|capitalize ~ ' Document Sync' %}
{% set maturityLabel = 'legacy' %}

{% block page_content %}

    <div class="row mb-1">
        <div class="col-md-12">
            <h2>{{ doc_type | capitalize }} Document Sync Status</h2>
            <p>Synced docs have a valid documentUrl and are properly linked to their parent entity</p>
            <p><b>Docs synced: {{ total_count - unsynced_docs|length }} / {{ total_count }}</b></p>
            {% set total_sync = (total_count - unsynced_docs|length) * 100 / total_count %}
            <div class="progress mb-3">
                <div class="progress-bar {% if total_sync >= 100 %}progress-bar-success{% endif %}" role="progressbar" aria-valuenow="{{ total_sync }}" aria-valuemin="0" aria-valuemax="100" style="width: {{ total_sync }}%;">
                    <span class="sr-only">{{ total_sync }}% Complete</span>
                </div>
            </div>
        </div>
        <div class="col-md-12 mb-1">
            <h3>Desynced {{ doc_type | capitalize }} Documents - <b>{% if unsynced_docs | length == 0 %}None{% else %}{{ unsynced_docs | length }} Unsyncable{% endif %}</b></h3>
            <p>Desynced documents (listed in table below) should be deleted and re-uploaded. Please go to the corresponding {{ doc_type | capitalize }} Documents table to delete them.</p>
        </div>
    </div>
    <table class="table table-striped datatable " id="unsyncable-doc-list">
        <thead>
            <tr>
                <th>{{ doc_type | capitalize }} Doc Id</th>
                <th>Internal id</th>
                <th>File Name</th>
                <th>Description</th>
                <th>Tag</th>
                <th>Doc Url</th>
                {# <th>Actions</th> #}
            </tr>
        </thead>
        <tbody>
        {% for doc in unsynced_docs %}
           <tr>
                <td>{{ doc.id }}</td>
                <td>{{ doc.document.id }}</td>
                <td>{{ doc.document.filename }}</td>
                <td>{{ doc.document.description }}</td>
                <td>{{ doc.document.tag }}</td> 
                <td>{{ doc.document.documentUrl }}</td>               
            </tr>
        {% endfor %}
        </tbody>
    </table>

{% endblock page_content %}