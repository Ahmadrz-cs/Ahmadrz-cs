{{ include('admin/components/_kv_table.html.twig', {
    title: title|default(null),
    tableId: tableId|default("trade-order-info"),
    valueDefaultStyle: "tw-font-mono",
    kv: {
        "Id": tradeOrder.id,
        "Uuid": tradeOrder.uuid,
        "Direction": tradeOrder.direction.name|capitalize,
        "Order Type": tradeOrder.type.name|capitalize,
        "Status": tradeOrder.status.value|capitalize,
        "Asset": "#" ~ tradeOrder.asset.id ~ " // " ~ tradeOrder.asset.name,
        "User": "#" ~ tradeOrder.user.id ~ " // " ~ tradeOrder.user.username,
        "Share Quantity": tradeOrder.numberOfShares|default(0)|number_format,
        "Share Price": tradeOrder.pricePerShare|default(0)|string|format_currency('GBP', {fraction_digit: 6}),
        "Derived Trade Value": (tradeOrder.pricePerShare * tradeOrder.numberOfShares)|default(0)|string|format_currency('GBP'),
        "Aggregate Shares Available": tradeOrder.sharesAvailable|default(0)|number_format,
        "Fees": tradeOrder.fees|default(0)|string|format_currency('GBP'),
        "Taxes": tradeOrder.taxes|default(0)|string|format_currency('GBP'),
        "Notes": tradeOrder.notes,
        "Min Share Quantity": tradeOrder.minimumShares is not null ? tradeOrder.minimumShares|number_format : 'N/A',
        "Max Share Quantity": tradeOrder.maximumShares is not null ? tradeOrder.maximumShares|number_format : 'N/A',
        "Prefunding Complementary Order Id": tradeOrder.complementaryOrder.id|default('N/A'),
        "Transaction Reference": tradeOrder.transactionReference|default('N/A'),
        "Transaction": tradeOrder.transaction ? "#" ~ tradeOrder.transaction.id ~ " // " ~ tradeOrder.transaction.externalId  : 'N/A',
        "Expiration": tradeOrder.expiration ? tradeOrder.expiration|date('Y-m-d H:i:s') : 'N/A',
        "Created At": tradeOrder.createdAt ? tradeOrder.createdAt|date('Y-m-d H:i:s') : 'N/A',
        "Created By": tradeOrder.createdBy|default('N/A'),
        "Updated At": tradeOrder.updatedAt ? tradeOrder.createdAt|date('Y-m-d H:i:s') : 'N/A',
        "Updated By": tradeOrder.updatedBy|default('N/A'),
    }
}) }}