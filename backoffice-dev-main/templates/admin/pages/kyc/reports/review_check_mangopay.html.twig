{% extends 'admin/layouts/cms.html.twig' %}

{% set backToRoute = 'admin_kyc_report_index' %}
{% set areaHeading = 'KYC Reports' %}
{% set mainHeading = 'Review Required Checker' %}
{% set maturityLabel = 'alpha' %}

{% form_theme form with ['bootstrap_5_layout.html.twig'] only %}

{% block page_content %}

	{{ include('admin/components/_alert.html.twig', {
		variant: "notice",
		title: "Rough Tooling",
		message: "This tool is fairly rough as it is intended as a stop gap. It will likely be mothballed in favour of allowing individual review checks within KycReport view.",
	}) }}

	{% embed 'admin/components/_bordered_section.html.twig' with {
        "sectionId": 'config-metadata',
        "sectionTitle": 'Configuration and Metadata',
    } %}
		{% block sectionContent %}
			{{ include('admin/components/_kv_table.html.twig', {
				tableId: "review-checker-info",
				title: "Review Checker Tracker",
				valueDefaultStyle: "tw-font-mono",
				kv: {
					"Status": taskTracker.tasks.reviewCheck.value|capitalize,
					"Last Report Id": taskTracker.metadata.lastReportId|default("N/A"),
					"Last Run At": taskTracker.metadata.lastRunAt|default("N/A"),
					"Remaining Reports": preview.nbResults,
					"All Metadata": {
						value: taskTracker.metadata|default([]),
						format: 'json',
					},
				}
			}) }}
		
			{{ form_start(form) }}
				<div class="row">
					<div class="col-md-6">{{ form_row(form.batchSize) }}</div>
					<div class="col-md-6">{{ form_row(form.skipToReportId) }}</div
				</div>
				<div class="mt-3">
					<div class="col-md-6">{{ form_row(form.submit) }}</div>
				</div>
			{{ form_end(form) }}
		{% endblock %}
	{% endembed %}

	{% embed 'admin/components/_bordered_section.html.twig' with {
        "sectionId": 'report-batch-preview',
        "sectionTitle": 'Report Batch Preview',
    } %}
		{% block sectionContent %}
			<div class="table-responsive">
				<table class="table" id="kyc-reports-list">
					<thead>
						<tr>
							{# <th>Actions</th> #}
							<th>Id</th>
							<th>Subject Id</th>
							<th>Subject Username</th>
							<th>Outcome</th>
							<th>KYC Provider</th>
							<th>Reference Id</th>
							<th>Check Type</th>
							<th>Result</th>
							<th>Score</th>
							<th>Checked At</th>
						</tr>
					</thead>
					<tbody>
						{% for report in preview %}
							<tr data-object-id="{{ report.id }}">
								{# <td>
									<a class="btn btn-outline-primary mt-1" href="{{ path('admin_kyc_report_view', { id: report.id }) }}">View</a>
								</td> #}
								<td>{{ report.id }}</td>
								<td>{{ report.subject.id }}</td>
								<td>{{ report.subject.username }}</td>
								<td>{{ report.verified ? 'Verified' : 'Failed' }}</td>
								<td>{{ report.providerName }}</td>
								<td>{{ report.providerReferenceId }}</td>
								<td>{{ report.checkType }}</td>
								<td>{{ report.result }}</td>
								<td>{{ report.score }}</td>
								<td>{{ report.checkedAt|date("Y-m-d H:i:s") }}</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		{% endblock %}
	{% endembed %}

{% endblock page_content %}
