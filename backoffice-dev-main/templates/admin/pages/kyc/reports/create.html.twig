{% extends 'admin/layouts/cms.html.twig' %}

{% set backToRoute = 'admin_kyc_report_index' %}
{% set areaHeading = 'KYC Reports' %}
{% set mainHeading = 'Create New KYC Report' %}
{% set maturityLabel = 'beta' %}

{% form_theme form with ['bootstrap_5_layout.html.twig'] only %}

{% block page_content %}

	{% embed 'admin/components/_bordered_section.html.twig' with {
        "sectionId": "immutable-warning",
        "sectionTitle": "Not Editable after Creation",
        "sectionStyle": "border rounded-3 p-4 border-warning",
    } %}
		{% block sectionContent %}
			{{ include('admin/components/_alert.html.twig', {
				variant: "warning",
				message: "KYC reports cannot be edited after creation. They act like a log of previous KYC checks.",
			}) }}
			{{ include('admin/components/_alert.html.twig', {
				variant: "notice",
				message: "KYC reports should be generated by the system automatically. Avoid creating manual KYC reports.",
			}) }}
		{% endblock %}
	{% endembed %}

	{% embed 'admin/components/_bordered_section.html.twig' with {
        "sectionId": 'kyc-report-form',
        "sectionTitle": 'KYC Report Configuration',
    } %}
		{% block sectionContent %}
			{{ form_start(form) }}
			<div class="row">
				<div class="col-md-6">{{ form_row(form.user, {attr: {'class': 'searchable'}}) }}</div>
				<div class="col-md-6">{{ form_row(form.checkedAt) }}</div>
				<div class="col-md-6">{{ form_row(form.providerName) }}</div>
				<div class="col-md-6">{{ form_row(form.providerReferenceId) }}</div>
				<div class="col-md-6">{{ form_row(form.checkType) }}</div>
				<div class="col-md-6">{{ form_row(form.result) }}</div>
				<div class="col-md-6">{{ form_row(form.score) }}</div>
				<div class="col-sm-6">
					<label class="card card-body bg-light shadow-none border">
						{{ form_widget(form.verified) }}
					</label>
				</div>
				<div class="col-12">{{ form_row(form.note) }}</div>
			</div>
			<div class="mt-3">
				<button class="btn btn-success" id="submit" type="submit">Create Kyc Report</button>
				<a class="btn btn-outline-secondary" href="{{ path('admin_kyc_report_index') }}">Abandon</a>
			</div>
			{{ form_end(form) }}
		{% endblock %}
	{% endembed %}

{% endblock page_content %}
