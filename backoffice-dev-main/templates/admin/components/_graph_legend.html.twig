{# {% set graphLegend = [
    {
        "color": "text-success",
        "label": "label",
        "value": "value",
    }
] %} #}

<div class="{{ layoutClass|default('d-flex flex-column gap-2') }}">
    {% for item in graphLegend %}
        <div class="d-flex tw-text-sm">
            <svg class="{{ item.color }} rounded-2 me-2" 
                width="20"
                height="20"
                role="img"
                aria-label="graph-legend" 
                version="1.1"
                focusable="false"
                xmlns="http://www.w3.org/2000/svg"
            >
                <rect width="100%" height="100%" fill="currentColor"></rect>
            </svg>
            <span class="me-auto">{{ item.label }}</span>

            {% if item.value is defined %}
            <span class="fw-bold text-end"
                data-field-name={{ item.label|lower|replace({' ': '-'}) }}
            >{{ valueUnitPrepend|default() }}{{ item.value }}{{ valueUnitAppend|default() }}</span>
            {% endif %}
            
        </div>
    {% endfor %}
</div>