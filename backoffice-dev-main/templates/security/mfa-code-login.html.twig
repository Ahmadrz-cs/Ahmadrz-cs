{% extends 'lava/lavabase.html.twig' %}

{% block title %}Login{% endblock title %}
{% block html_title %}Login{% endblock html_title %}

{% block pageclass %} login-page{% endblock pageclass %}

{% block body %}
<main role="main" class="container mb-5">
    <nav class="row justify-content-between mt-3">
        <div class="col">
            <a href="{{ consumer_app_url }}">
                <img class="logo-nav mb-2" src="{{ asset('build/images/logo_wordmark_contained.svg') }}" height="40" loading="lazy" alt="yielders logo">
            </a>
        </div>
    </nav>

    <section class="row justify-content-center mt-2 mt-sm-5 py-5">
        <div class="col-md-10 col-lg-8 col-xl-6">
            <h3>Two-Factor Authentication</h3>
            {# {% if error %}
            <div class="alert alert-danger alert-dismissible">
                <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
            {% endif %} #}
            {% if authenticationError %}
                <div class="alert alert-danger alert-dismissible">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    {{ authenticationError|trans(authenticationErrorData, 'SchebTwoFactorBundle') }}
                </div>
            {% endif %}

            <form action="{{ path("2fa_login_check") }}" method="post">
                {% if isCsrfProtectionEnabled %}
                <input type="hidden" name="{{ csrfParameterName }}" value="{{ csrf_token(csrfTokenId) }}">
                {% endif %}
                <p class="">{% block codeprompt %}Enter the authentication code{% endblock codeprompt %}</p>
                <div class="form-row">
                    <div class="form-group col-12 has-feedback">
                        {#
                            https://www.twilio.com/blog/html-attributes-two-factor-authentication-autocomplete
                            If your 2fa methods are using numeric codes only, add these attributes for better user experience:
                            inputmode="numeric"
                            pattern="[0-9]*"
                        #}
                        <label for="_auth_code" class="form-label">Two-factor authentication code</label>
                        <input id="_auth_code" type="text" name="{{ authCodeParameterName }}" autocomplete="one-time-code" autofocus inputmode="numeric" pattern="[0-9]*" class="form-control" required="required" />
                    </div>
                    <div class="form-group col-12 has-feedback">
                        {% if displayTrustedOption %}
                        <label for="_trusted">
                            <input id="_trusted" type="checkbox" name="{{ trustedParameterName }}" />
                            {{ "trusted"|trans({}, 'SchebTwoFactorBundle') }}. Remember me for 14 days
                        </label>
                        {% endif %}
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-sm-6">
                        <input type="submit" class="btn btn-primary rounded-pill btn-lg btn-block w-100" value="{{ "Verify Code"|trans({}, 'SchebTwoFactorBundle') }}" />
                    </div>
                    <div class="col-sm-6 d-flex flex-column justify-content-center mt-3 mt-sm-0">
                        <a class="d-block btn btn-link text-sm-end py-2 py-sm-1" href="{{ logoutPath }}">{{ "cancel"|trans({}, 'SchebTwoFactorBundle') }}</a>
                    </div>
                </div>
            </form>
        </div>
    </section>
</main>
{% endblock %}