{
    "name": "yielders2/backoffice-dev",
    "license": "proprietary",
    "type": "project",
    "description": "Yielders CMS and API",
    "require": {
        "php": "^8.4",
        "ext-bcmath": "*",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "aws/aws-sdk-php-symfony": "^2.1",
        "babdev/pagerfanta-bundle": "^4.0",
        "beberlei/doctrineextensions": "^1.2",
        "bramus/monolog-colored-line-formatter": "~3.1",
        "defuse/php-encryption": "^2.2",
        "doctrine/common": "^3.0",
        "doctrine/dbal": "^4.0",
        "doctrine/doctrine-bundle": "^2.0",
        "doctrine/doctrine-migrations-bundle": "^3.2",
        "doctrine/orm": "^3.3",
        "endroid/qr-code-bundle": "^6.0",
        "friendsofsymfony/rest-bundle": "^3.0",
        "guzzlehttp/guzzle": "^7.0",
        "jms/serializer-bundle": "^5.2",
        "lcobucci/jwt": "^5.0",
        "league/csv": "^9.0",
        "league/flysystem": "^3",
        "league/flysystem-aws-s3-v3": "^3.0",
        "league/oauth2-server-bundle": "^1.0",
        "mailchimp/transactional": "^1.0",
        "mangopay4/php-sdk": "^4.0",
        "nelmio/api-doc-bundle": "^4.11",
        "nyholm/psr7": "^1.3",
        "ocramius/proxy-manager": "^2.0",
        "oneup/flysystem-bundle": "^4.0",
        "pagerfanta/doctrine-collections-adapter": "*",
        "pagerfanta/doctrine-orm-adapter": "*",
        "pagerfanta/twig": "*",
        "phpdocumentor/reflection-docblock": "^5.2",
        "sameer-shelavale/php-countries-array": "*",
        "scheb/2fa-bundle": "^7.4",
        "scheb/2fa-email": "^7.4",
        "scheb/2fa-totp": "^7.4",
        "scheb/2fa-trusted-device": "^7.4",
        "sonata-project/exporter": "^3.0",
        "stof/doctrine-extensions-bundle": "^1.2",
        "symfony/amazon-sqs-messenger": "7.4.*",
        "symfony/asset": "7.4.*",
        "symfony/console": "7.4.*",
        "symfony/doctrine-messenger": "7.4.*",
        "symfony/dotenv": "7.4.*",
        "symfony/expression-language": "7.4.*",
        "symfony/flex": "^2.0",
        "symfony/form": "7.4.*",
        "symfony/framework-bundle": "7.4.*",
        "symfony/html-sanitizer": "7.4.*",
        "symfony/intl": "7.4.*",
        "symfony/mailer": "7.4.*",
        "symfony/messenger": "7.4.*",
        "symfony/mime": "7.4.*",
        "symfony/monolog-bundle": "^3.8",
        "symfony/polyfill-intl-grapheme": "^1.26",
        "symfony/property-access": "7.4.*",
        "symfony/property-info": "7.4.*",
        "symfony/psr-http-message-bridge": "7.4.*",
        "symfony/redis-messenger": "7.4.*",
        "symfony/runtime": "7.4.*",
        "symfony/scheduler": "7.4.*",
        "symfony/security-bundle": "7.4.*",
        "symfony/serializer": "7.4.*",
        "symfony/translation": "7.4.*",
        "symfony/twig-bundle": "7.4.*",
        "symfony/uid": "7.4.*",
        "symfony/validator": "7.4.*",
        "symfony/webpack-encore-bundle": "^2.0",
        "symfony/workflow": "7.4.*",
        "symfonycasts/reset-password-bundle": "^1.13",
        "symfonycasts/verify-email-bundle": "^1.9",
        "twig/extra-bundle": "^3.6",
        "twig/intl-extra": "^3.6"
    },
    "require-dev": {
        "codeception/codeception": "^5.0",
        "codeception/module-asserts": "*",
        "codeception/module-db": "*",
        "codeception/module-phpbrowser": "*",
        "doctrine/doctrine-fixtures-bundle": "^4.0",
        "liip/test-fixtures-bundle": "^3.0",
        "liuggio/fastest": "~1.6",
        "phpstan/extension-installer": "^1.1",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpunit/php-code-coverage": "^12.0",
        "phpunit/phpunit": "^12",
        "psalm/plugin-phpunit": "*",
        "psalm/plugin-symfony": "*",
        "rector/rector": "^2.0",
        "symfony/browser-kit": "7.4.*",
        "symfony/css-selector": "7.4.*",
        "symfony/debug-bundle": "7.4.*",
        "symfony/maker-bundle": "^1.0",
        "symfony/phpunit-bridge": "7.4.*",
        "symfony/stopwatch": "7.4.*",
        "symfony/var-dumper": "7.4.*",
        "symfony/web-profiler-bundle": "7.4.*",
        "symplify/easy-coding-standard": "^12",
        "theofidry/alice-data-fixtures": "^1.4",
        "vimeo/psalm": "^6"
    },
    "config": {
        "prepend-autoloader": false,
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "endroid/installer": true,
            "symfony/flex": true,
            "phpstan/extension-installer": true,
            "symfony/runtime": true
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "paragonie/random_compat": "2.*",
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php70": "*",
        "symfony/polyfill-php56": "*"
    },
    "scripts": {
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        }
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "public-dir": "public",
        "symfony": {
            "allow-contrib": false,
            "require": "7.4.*"
        }
    }
}
