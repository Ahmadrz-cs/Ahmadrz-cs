<article class="border rounded-lg tw-p-4">
	<div class="d-flex flex-column text-md gap-y-2">
		<div class="d-flex justify-content-between align-items-center gap-y-2 text-muted text-sm">
			<div data-field-name="creation-date">{{ payout.createdAt|date(dateformat|default('Y-m-d')) }}</div>
			<div data-field-name="type">{{ payout.type.name }}</div>
		</div>
		{% if showAsset ?? false %}
			<div class="d-flex justify-content-between align-items-center gap-y-2">
				<div class="font-semibold" data-field-name="asset-name">{{ payout.assetName }}</div>
			</div>
		{% endif %}
		<div class="d-flex justify-content-between align-items-center gap-y-2">
			<div class="font-semibold" data-field-name="value">{{ payout.value|format_currency('GBP') }}</div>
			<div class="font-semibold" data-field-name="shareholding">{{ payout.shares|number_format(0, '.', ',') }} shares</div>
		</div>
	</div>
</article>
