{% if active is not defined %}
{% set active = '' %}
{% endif %}
{% if sub_active is not defined %}
{% set sub_active = '' %}
{% endif %}

{% set authenticated = app.session.get('authenticated')|default(false) %}
{% set hasUserInfo = app.session.has('userInfo') %}
{% set userInfo = app.session.get('userInfo')|default([]) %}

{% extends '@AppBundle/base.html.twig' %}

{% block body %}
<main role="main">
    {% include '@AppBundle/Common/portfoliobanner.html.twig' %}
    <header class="mt-4">{% include '@AppBundle/Common/portfolionav.html.twig' %}</header>
    <section class="container">
        <h3 class="text-center mb-3">You currently have ({{ prefundingRepayments.positions|filter(v => v.shares > 0)|length }}) prefunding investments</h3>
        <p>If you have participated in the prefunding of a property, any prefunding investment (that you have not chosen to keep) will be gradually returned to you as the property is sold to retail investors. You can track the progress of this below.</p>
        <div class="table-responsive mb-2">
            <h4 class="sr-only">Prefunding Investments</h4>
            <table class="grid-table table table-borderless table-custom font-medium gfg dataTable"
                id="prefunding-investments">
                <thead class="p-3 font-medium">
                    <th class="table-custom-hd">Asset Name</th>
                    <th class="table-custom-hd">Original Shares</th>
                    <th class="table-custom-hd">Remaining Shares</th>
                    <th class="table-custom-hd">Original Value</th>
                    <th class="table-custom-hd">Remaining Value</th>
                    <th class="table-custom-hd">Repayment Progress</th>
                </thead>
                <tbody>
                    {% for repayments in prefundingRepayments.positions|filter(v => v.shares > 0)|default([]) %}
                    <tr class="mb-1 grid-table-4 border">
                        <td class="table-custom-data grid-order-1 grid-text-left grid-span-3"
                            data-label="Asset Name">
                            <span class="table-custom-value">{{ repayments.assetName }}</span>
                        </td>
                        <td class="table-custom-data grid-order-3 grid-text-left grid-span-2 show-label mb-2 mb-lg-0"
                            data-label="Original Shares">
                            <span class="table-custom-value">{{
                                repayments.buyShares|number_format(0, '', ',') }}
                            </span>
                        </td>
                        <td class="table-custom-data grid-order-5 grid-text-left grid-span-2 show-label mb-2 mb-lg-0"
                            data-label="Remaining Shares">
                            <span class="table-custom-value">{{
                                repayments.shares|number_format(0, '', ',') }}
                            </span>
                        </td>
                        <td class="table-custom-data grid-order-4 grid-text-right show-label"
                            data-label="Original Value">
                            <span class="table-custom-value">£{{
                                repayments.buyValue|number_format(2, '.', ',') }}
                            </span>
                        </td>
                        <td class="table-custom-data grid-order-6 grid-text-right show-label"
                            data-label="Remaining Value">
                            <span class="table-custom-value">£{{
                                repayments.value|number_format(2, '.', ',') }}
                            </span>
                        </td>
                        <td class="table-custom-data grid-order-7 grid-text-left grid-span-4 show-label"
                            data-label="Liquidation Progress">
                            <div class="progress mt-1 mt-lg-0" class="table-custom-value">
                                {% set liquidationProgress = (repayments.sellShares * 100 / repayments.buyShares)|number_format(1) %}
                                <div class="progress-bar bg-success text-body" role="progressbar" style="width: {{ liquidationProgress }}%;" aria-valuenow="25" aria-valuemin="0" aria-valuemax="100">{{ liquidationProgress }}%</div>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </section>

</main>

{% endblock %}