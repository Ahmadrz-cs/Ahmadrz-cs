<article class="border rounded-lg tw-p-4" {% if not (showId ?? false) %}data-uuid="{{ trade.uuid }}"{% endif %}>
	<div class="d-flex flex-column text-md gap-y-2">
		<div class="d-flex justify-content-between align-items-center gap-y-2 text-muted text-sm">
			<div data-field-name="creation-date">{{ trade.createdAt|date(dateformat|default('Y-m-d')) }}</div>
			<div data-field-name="status">{{ trade.status.value|capitalize }}</div>
		</div>
		{% if showAsset ?? false %}
			<div class="d-flex justify-content-between align-items-center gap-y-2">
				<div class="font-semibold" data-field-name="asset-name">{{ trade.assetName }}</div>
			</div>
		{% endif %}
		<div class="d-flex justify-content-between align-items-center gap-y-2">
			<div class="font-semibold" data-field-name="value">{{ trade.tradeValue|format_currency('GBP') }}</div>
			<div class="font-semibold">
				<span data-field-name="shares">{{ trade.numberOfShares|number_format(0, '.', ',') }}</span>
				<span>shares @</span>
				<span data-field-name="price">{{ trade.pricePerShare|format_currency('GBP') }}</span>
			</div>
		</div>
		{% if showId ?? false %}
		<div class="d-flex justify-content-between align-items-center gap-y-2">
			<div class="text-muted text-sm" data-field-name="uuid">{{ trade.uuid }}</div>
		</div>
		{% endif %}
	</div>
</article>
