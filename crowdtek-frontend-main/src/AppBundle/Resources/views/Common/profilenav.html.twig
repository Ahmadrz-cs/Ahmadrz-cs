  <script>
        $(document).ready(function(){
			$('.navClick').removeClass('active');
			let urlSegments = $(location).attr('href').split('/').reverse()
            let lastSegUrl = urlSegments[0];
			let penultSegUrl = urlSegments[1];
			if(lastSegUrl == 'categorisation' || penultSegUrl == 'categorisation'){
				$('#proCategorisation').addClass('active');
			}
			else if(lastSegUrl=='profile'){
				$('#proGeneral').addClass('active');

			}else if(lastSegUrl=='password-security'){
				$('#proSecurity').addClass('active');

			} else if(lastSegUrl=='apply-top-yielder'){
				$('#proTopYielders').addClass('active');

			} else if(lastSegUrl=='transactions' || lastSegUrl=='transaction-export'){
				$('#proTransaction').addClass('active');

			} else if(lastSegUrl=='direct-debit'){
				$('#proDirectDebit').addClass('active');

			} else if(lastSegUrl=='feedback'){
				$('#proFeedback').addClass('active');
			} else if(lastSegUrl=='contact-preferences'){
				$('#proContactPreferences').addClass('active');
			} else if(urlSegments.some(str => str.includes('bank-accounts'))){
				$('#proBankAccounts').addClass('active');
			} else{
				$('#proDashboard').addClass('active');
			}

			if($(window).width() >= 768) {
           		$("#profilenav").removeClass("asidenav");
        	}else{
           		$("#profilenav").addClass("asidenav");  
			}

        });
        </script>