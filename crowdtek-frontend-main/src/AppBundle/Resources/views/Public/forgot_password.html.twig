{% extends '@AppBundle/base.html.twig' %}

{% block title %}Forgot Password{% endblock %}
{% block stylesheets %}
    <link href="{{ asset('bundles/app/css/bootstrap-datetimepicker.min.css') }}" rel="stylesheet">{% endblock %}
{% block body %}
    	<!-- hero banner -->
	<div class="hero-banner blog-detail banner-medium bg-fixed bg-overlay">
		<div class="container pt-6 pt-md-8 position-relative layer-z-1">
			<div class="hero-banner-content pr-2 py-4 text-center">
				<div class="row">
					<div class="col-lg-9 mx-auto">
					</div>
				</div>
			</div>
		</div>
	</div>
    <section id="complete-registration" class="forgot-password">
        <div class="container">
                
            <div class="card p-4 mt-n4 mb-7">
                    <h2 class="h3 mb-3">
							Forgot Password
						</h2>
                <form id="forgot_pwd_type" name="forgot_pwd_type" method="post" action="" class="" role="form">
                {% if result == 'success' %}
                    <div >
                        Instructions for resetting your password have now been sent to you. Please check your email.
                    </div>
                {% else %}

                    {% if (error_code == 10009) or (error_code == 10010) %}
                        <p style="color:red">Error: Invalid Data</p>
                    {% elseif error_code == 10011 %}
                        <p style="color:red">User does not exists</p>
                    {% elseif error_code == 10012 %}
                        <p style="color:red">Invalid Email Address</p>
                    {% endif %}
                    <br>
                    <div class="mb-1">Please enter your e-mail address and instructions to reset your password will be sent to you.</div>
                    <div class="forgot-pw-input">
                        <div class="form-group">
                            {{ form_widget(form.email, {'attr': {'class': 'form-control','placeholder':'Enter Email','data-validation':'email'}}) }}
                        </div>
                        <div class="form-group">
                            {{ form_widget(form.submit, {'attr': {'class': 'btn btn-primary rounded-pill px-2'}, 'label': 'Send'} ) }}
                        </div>
                    </div>
                {% endif %}
                </form>
            </div>
        </div><!--/.container-->
    </section><!--/about-us-->
{% endblock %}

