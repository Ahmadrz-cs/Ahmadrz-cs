                height: 40px;
                display: inline-block;
                position: relative;
                top: 8px;
            }

            .info-tab {
                float: left;
                margin-left: -23px;
            }

            .note-icon {
                background: #47ADE0;
            }

            .note-box {
                color: rgba(63, 110, 106, 0.9376);
                background-color: #d6eceb;
                padding: 8px 8px 3px 14px;
            }
