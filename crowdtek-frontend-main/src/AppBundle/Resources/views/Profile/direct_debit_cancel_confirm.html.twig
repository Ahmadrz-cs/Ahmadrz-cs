    </main>
{% endblock %}


{% block pagejs %}

    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.13.0/js/all.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.13.0/css/all.min.css"></script>


    <script type="text/javascript">

        var inp = $("#setup_direct_debit_type_amount")[0];

        inp.addEventListener("input", function () {

            checkAmountValid();

            var value = parseFloat(this.value) + 0.60;
            console.log(parseFloat(value));
            if (Number.isNaN(value)) {
                document.querySelector('#first-payment-amount').innerHTML = ''
                document.querySelector('#second-payment-amount').innerHTML = ''
                document.querySelector('#third-payment-amount').innerHTML = ''
            }
            else {
                document.querySelector('#first-payment-amount').innerHTML = '£' + value.toFixed(2);
                document.querySelector('#second-payment-amount').innerHTML = '£' + value.toFixed(2);
                document.querySelector('#third-payment-amount').innerHTML = '£' + value.toFixed(2);

            }
        }, false);

        // Restricts input for the given textbox to the given inputFilter.
        function setInputFilter(textbox, inputFilter) {
            ["input", "keydown", "keyup", "mousedown", "mouseup", "select", "contextmenu", "drop"].forEach(function(event) {
                textbox.addEventListener(event, function() {
                    if (inputFilter(this.value)) {
                        this.oldValue = this.value;
                        this.oldSelectionStart = this.selectionStart;
                        this.oldSelectionEnd = this.selectionEnd;
                    } else if (this.hasOwnProperty("oldValue")) {
                        this.value = this.oldValue;
                        this.setSelectionRange(this.oldSelectionStart, this.oldSelectionEnd);
                    } else {
                        this.value = "";
                    }
                });
            });
        }

        setInputFilter(document.getElementById("setup_direct_debit_type_amount"), function(value) {
            return /^-?\d*[.,]?\d{0,2}$/.test(value); });


        $(document).ready(function () {

            $('input:radio[name="setup_direct_debit_type[bankAccountType]"]').change(function() {
                if (this.value == 'eu bank account') {
                    $("label[for=account-iban-number]").html("IBAN");
                    $("label[for=sort-bic]").html("BIC/SWIFT");
                    $('#small-account-helper').html("(IBAN) International Bank Account Number");
                    $('#small-sort-helper').html(" 8 or 11 character BIC/SWIFT code");
                } else if (this.value == 'uk bank account') {
                    $("label[for=account-iban-number]").html("Account Number");
                    $("label[for=sort-bic]").html("Sort Code");
                    $('#small-account-helper').html("8 Digit Acccount Number");
                    $('#small-sort-helper').html("6 Digit Sort Code");
                }
            });

        });

        var form = $("form[name='setup_direct_debit_type']");

        form.addEventListener("submit", checkAmountValid(), false);

        function checkAmountValid() {
            var amount=parseFloat(document.getElementById("setup_direct_debit_type_amount").value);
            if(amount < 50) {
                $('#setup_direct_debit_type_amount').addClass('input_error_highlight');
                $('div#belowMinPrompt').removeClass('d-none');
                return false;
            }
            else {
                $('#setup_direct_debit_type_amount').removeClass('input_error_highlight');
                $('div#belowMinPrompt').addClass('d-none');
                return true;
            }
        }

        function check(e){
            e.preventDefault();
            if (checkAmountValid()){
                submit.submit();
            }
        }

    </script>
{% endblock %}
