{% for type, flash_messages in app.session.flashBag.all %}
    {% for flash_message in flash_messages %}
        {% if type == 'errors' %}
<div class="alert alert-danger mt-4">

    {% else %}
    <div class="alert alert-{{ type }}">
        {% endif %}

        {{ flash_message }}
    </div>
    {% endfor %}
    {% endfor %}
