{% extends "@AppBundle/onboarding-base.html.twig" %}

{% if active is not defined %}
    {% set active = '' %}
{% endif %}
{% if sub_active is not defined %}
    {% set sub_active = '' %}
{% endif %}

{% set hasUserInfo = false %}
{% set authenticated = false %}
{% if app.session.has('authenticated') %}
    {% set authenticated = app.session.get('authenticated') %}
{% endif %}
{% set userInfo = [] %}
{% if app.session.has('userInfo') %}
    {% set hasUserInfo = app.session.has('userInfo') %}
    {% set userInfo = app.session.get('userInfo') %}
{% endif %}

{% block stylesheets %}
{% endblock %}

{% block bodystyle %}
    class="section_wrap_2"
{% endblock %}

{% block body %}
    <section class="wrap">
        {% include '@AppBundle/Onboarding/sidebar-left.html.twig' %}

        <div class="col-md-9 right_section">
            {% include '@AppBundle/Onboarding/errorflash.html.twig' %}
            <div class="row">

            {% if authenticated %}

                <div class="form-step js-form-step" id="completion-message">
                    <div class="pdg_20">
                        {% set message = "Your information has been submitted, all information should be processed within 1-2 working days." %}
                        {% if userInfo.has_been_approved|default() and userInfo.registration_complete|default() %}
                            {% set message = "Thank you for completing your registration & compliance." %}
                        {% endif %}
                        <div class="successfull">
                            <img src="{{ asset('bundles/app/images/onboarding/icons/sml.png') }}" loading="lazy" alt="success indicator">
                            <h3>Congratulations!</h3>
                            <p>{{ message }}</p>
                            <a class="btntest" href="{{ path('product_properties_current') }}">View Properties</a>
                        </div>
                    </div>
                </div>

            {% endif %}
        </div>
            </div>
    </section>

{% endblock %}

{% block scripts %}
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.1.1/jquery.min.js"></script>
{% endblock %}