{% extends "@AppBundle/onboarding-base.html.twig" %}

{% if active is not defined %}
    {% set active = '' %}
{% endif %}
{% if sub_active is not defined %}
    {% set sub_active = '' %}
{% endif %}

{% set hasUserInfo = false %}
{% set authenticated = false %}
{% if app.session.has('authenticated') %}
    {% set authenticated = app.session.get('authenticated') %}
{% endif %}
{% set userInfo = [] %}
{% if app.session.has('userInfo') %}
    {% set hasUserInfo = app.session.has('userInfo') %}
    {% set userInfo = app.session.get('userInfo') %}
{% endif %}

{% block stylesheets %}
{% endblock %}

{% block body %}

    <section class="wrap">
        {% include '@AppBundle/Onboarding/sidebar-left.html.twig' %}

        <div class="col-md-9 right_section">
            {% include '@AppBundle/Onboarding/errorflash.html.twig' %}
            <div class="row">

                {% if authenticated %}

                    <div class="form-step js-form-step" id="completion-message">
                        <div class="pdg_20">

                            <div class="faild">
                                <img src="{{ asset('bundles/app/images/onboarding/icons/fail.png') }}" loading="lazy" alt="fail indicator">
                                <h3>Oops something went wrong </h3>
                                <p>[ {{ response_error }} ]</p>
                                <p>An error ocurred while trying to onboard you.</p>
                                <p>To try again please <a href="{{ path(app.request.get('Onboarding')) }}">Click Here</a></p>
                                <p>Alternatively, if the issue persists, please contact the Yielders team on +44 2072054650
                                or email on <a href="mailto:team@yielders.co.uk?subject=Onboarding Failed">team@yielders.co.uk</a></p>
                            </div>
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>
    </section>
{% endblock %}
