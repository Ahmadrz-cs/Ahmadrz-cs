{% extends '@AppBundle/base.html.twig'%}
{# {% block title %}Page title override{% endblock %} #}
{% block body %}


	<main
		role="main">

		<section>
            <h1 class="sr-only">Page Promotion</h1>
            <div class="hero-banner home slide1 bg-fixed">
                <div class="container pt-6 pt-md-8 d-flex align-items-center h-100">
                    <div class="hero-banner-content pr-2 mt-5" style="min-width:0;">  
                        <div class="row">
							<div class="col-9 col-sm-7">
								<h2 class="h1 hero-banner-hd text-light mb-3">
									Fair share of property
								</h2>
								<p class="hero-banner-dtls text-light mb-4">
									Start from as low as £100. Ethical investing doesn't mean less profits.
								</p>
							</div>
						</div>
                        <!-- buttons -->
                        <div class="row">
                            <div class="col-lg-12">
                                <p class="mb-0">
									{% if authenticated %}
										<a href="{{ path('product_properties_current') }}" class="btn btn-lg btn-secondary rounded-pill mb-3">Invest Now</a>
									{% else %}
										<a href="{{ path('Onboarding')}}" class="btn btn-lg btn-secondary rounded-pill mb-3">Sign up</a>
									{% endif %}
								</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

		<!-- items list -->
		{% if authenticated and not userInfo.registration_complete %}
		<div class="alert alert-warning mb-0 text text-center" role="alert">
  			<a class="h6 mb-0" href="{{ path('Onboarding')}}">Complete your onboarding</a>
		</div>
		{% endif %}
		<section class="bg-light">
			<h2 class="sr-only">Features</h2>
			<div class="container pl-4 pt-2">
				<div class="row grid-view features">
					<div class="col-md-6 col-lg-3">
						<div class="card border-dark">
							<div class="card-body text-center">
								<figure>
									<img src="{{asset('bundles/app/svg/')}}ethical.svg" loading="lazy" alt="" class="card-icon-height">
								</figure>
								<h5 class="card-title">Ethical Investing</h5>
								<p class="card-text">Shariah Compliant, no interest. Earn competitive returns from our investment opportunities. No Bank or Mortgage!</p>
							</div>
						</div>
					</div>
					<div class="col-md-6 col-lg-3">
						<div class="card border-dark">
							<div class="card-body text-center">
								<figure>
									<img src="{{asset('bundles/app/svg/')}}shield.svg" loading="lazy" alt="" class="card-icon-height">
								</figure>
								<h5 class="card-title">FCA Regulated</h5>
								<p class="card-text">Yielders is authorised and regulated by the Financial Conduct Authority (FCA).</p>
							</div>
						</div>
					</div>
					<div class="col-md-6 col-lg-3">
						<div class="card border-dark">
							<div class="card-body text-center">
								<figure>
									<img src="{{asset('bundles/app/svg/')}}multiple.svg" loading="lazy" alt="" class="card-icon-height">
								</figure>
								<h5 class="card-title">Multiple Returns</h5>
								<p class="card-text">Earn monthly rental income, plus a share of the total profit upon sale.
								</p>
								<a class="btn-underline font-medium" href="http://help.yielders.co.uk/en/articles/3436312-our-fees" target="_blank">See our fees here</a>
							</div>
						</div>
					</div>
					<div class="col-md-6 col-lg-3">
						<div class="card border-dark">
							<div class="card-body text-center">
								<figure>
									<img src="{{asset('bundles/app/svg/')}}home-lg.svg" loading="lazy" alt="" class="card-icon-height">
								</figure>
								<h5 class="card-title">Group</h5>
								<p class="card-text">We are now part of the Sama Group, a family of companies ingrained in real estate.</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		{% set featuredAssets = featuredAssets|sort((a, b) => b.featured <=> a.featured)|slice(0,2) %}
		{# {% set featuredAssets = featuredAssets|filter(a => a.sharesAvailable > 0)|sort((a, b) => b.featured <=> a.featured) %} #}
		
		<section class="bg-light">
			<div class="container pt-8 pb-6" id="featured-products">
				{% if featuredAssets|length > 0 %}
					<h2 class="text-center mb-3">Featured Properties</h2>
					<div class="row gap-y-5 justify-content-center">
						{% for entry in featuredAssets %}
							<article class="col-md-6 col-lg-4 d-flex align-items-stretch">
								{{ include('@AppBundle/Product/_asset_card.html.twig', {
									asset: entry,
									showFields: ["Net Projected Yield", "Target End Date"],
									showLink: false,
									showStatuses: false,
								}) }}
							</article>
						{% endfor %}
					</div>

					{% if authenticated|default(false) %}
						<div class="text-center mt-3">
							<a href="{{ path('product_properties_current') }}"
								class="btn btn-secondary rounded-pill px-2">View More Properties</a>
						</div>
					{% endif %}
				
				{% endif %}
			</div>
		</section>

		<!-- process explanation -->
		<div class="bg-dark pt-5 pb-5" id="how-it-works-process">
			<div class="container">
				<h2 class="text-center pt-5 mb-3">
					How it works
				</h2>
				<div class="row py-6">
					<div class="col-md-4 mb-4 mb-md-0 text-center">
						<div class="d-flex flex-row flex-md-column">
							<div class="px-2 px-md-0 howitwork-icon">
								<img src="{{asset('bundles/app/svg/')}}invest.svg" class="icon mb-3 img-fluid" loading="lazy" alt="">
							</div>
							<div class="pr-2 px-md-0 howitwork-content">
								<h5 class="mb-2 text-left text-md-center">Invest</h5>
								<p class="text-md text-left text-md-center">Buy shares in income producing property
									                                        investments from £100.
									                                        Choose how
									                                        many shares you wish to own in any available investment!</p>
							</div>
						</div>
					</div>
					<div class="col-md-4 mb-4 mb-md-0 text-center">
						<div class="d-flex flex-row flex-md-column">
							<div class="px-2 px-md-0 howitwork-icon">
								<img src="{{asset('bundles/app/svg/')}}grow.svg" class="icon mb-3 img-fluid" loading="lazy" alt="">
							</div>
							<div class="pr-2 px-md-0 howitwork-content">
								<h5 class="mb-2 text-left text-md-center">Grow</h5>
								<p class="text-md text-left text-md-center">As property prices grow so does the
									                                        value of your shares.
									                                        Track the
									                                        movements
									                                        from your online portfolio.</p>
							</div>
						</div>

					</div>
					<div class="col-md-4 mb-4 mb-md-0 text-center">
						<div class="d-flex flex-row flex-md-column">
							<div class="px-2 px-md-0 howitwork-icon">
								<img src="{{asset('bundles/app/svg/')}}yield.svg" class="icon mb-3 img-fluid" loading="lazy" alt="">
							</div>
							<div class="pr-2 px-md-0 howitwork-content">
								<h5 class="mb-2 text-left text-md-center">Yield</h5>
								<p class="text-md text-left text-md-center">Receive your share of the rental income
									                                        in the form of monthly
									                                        dividends
									                                        if
									                                        there are profits, and a share of any sale proceeds upon exit.</p>
							</div>
						</div>
					</div>
					<div class="col-md-12 text-center mt-4">
						<a href="{{ path('how_it_works') }}" class="btn-underline invert font-medium">Learn more</a>
					</div>
				</div>
			</div>
		</div>
	</section>

