{% if active is not defined %}
    {% set active = '' %}
{% endif %}
{% if sub_active is not defined %}
    {% set sub_active = '' %}
{% endif %}
{% set hasUserInfo = false %}
{% set authenticated = false %}
{% if app.session.has('authenticated') %}
    {% set authenticated= app.session.get('authenticated') %}
{% endif %}
{% set userInfo = [] %}
{% if app.session.has('userInfo') %}
    {% set hasUserInfo = app.session.has('userInfo') %}
    {% set userInfo = app.session.get('userInfo') %}
{% endif %}


{% extends '@AppBundle/base.html.twig' %}


{% block body %}
    <main class="my-6 pt-6 pt-md-8" role="main">
        <div class="container py-4 d-flex flex-column justify-content-center" style="min-height: 67vh;">
            <div class="row">
                <div class="col-12 col-md-6 offset-md-3 text-center">
                    <h3>Investor Appropriateness Test Failed</h3>
                    <p>Unfortunately, you did not pass the test. This means that investments offered by Yielders may not be suitable for you.</p>
                    <p>You can retry once immediately. But you must wait a week for any subsequent retries.</p>
                    <div class="d-flex justify-content-center p-4" style="gap: 0.5rem;">
                        <a class="btn btn-light rounded-pill px-1 px-sm-2" href={{ path('homepage') }} role="button">Leave</a>
                        {% if canTakeAssessment %}
                            <a class="btn btn-primary rounded-pill px-1 px-sm-2" href={{ path('checkup_assessment') }} role="button">Try Again</a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </main>
{% endblock %}
