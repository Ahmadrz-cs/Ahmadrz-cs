{% if active is not defined %}
    {% set active = '' %}
{% endif %}
{% if sub_active is not defined %}
    {% set sub_active = '' %}
{% endif %}
{% set hasUserInfo = false %}
{% set authenticated = false %}
{% if app.session.has('authenticated') %}
    {% set authenticated= app.session.get('authenticated') %}
{% endif %}
{% set userInfo = [] %}
{% if app.session.has('userInfo') %}
    {% set hasUserInfo = app.session.has('userInfo') %}
    {% set userInfo = app.session.get('userInfo') %}
{% endif %}

{% form_theme form with ['bootstrap_4_layout.html.twig'] only %}

{% extends '@AppBundle/base.html.twig' %}


{% block body %}
    <main class="my-6 pt-6 pt-md-8" role="main">
        <div class="container py-4 d-flex flex-column justify-content-center" style="min-height: 67vh;">
            <div class="row">
                <div class="col-12 col-md-8 offset-md-2 text-center d-flex flex-column" style="gap: 1rem;">
                    <h3>Investor Type Confirmation</h3>
                    <h5>
                        <b><u>Self-Certified Sophisticated Investor</u></b>
                    </h5>
                    <div class="border rounded p-3 mb-3 mt-2 text-left">
                        <p>You must confirm that you qualify as a self-certified sophisticated investor on the basis that A, B, C <span class="font-medium"> or </span>D apply to you. If not, you must choose a different investor type.</p>
                        <p>In the last two years have you:</p>
                        <ul>
                            <li>
                                <p>
                                    (A) worked in
                                    <b>private equity</b>
                                    or in the
                                    <b>provision of finance for small and medium enterprises?</b>
                                </p>
                            </li>
                            <li>
                                <p>
                                    (B) been the
                                    <b>director of a company</b>
                                    with an annual turnover of at least £1 million?
                                </p>
                            </li>
                            <li>
                                <p>
                                    (C) made two or more
                                    <b>investments in an unlisted company?</b>
                                </p>
                            </li>
                            <li>
                                <p>
                                    (D) been a
                                    <b>member of a network or syndicate of business angels for more than six months?</b>
                                </p>
                            </li>
                        </ul>
                        <p>Please confirm that either A, B, C <span class="font-medium"> or </span>D apply to you by answering the following:</p>
                        {{ form_start(form) }}
                            {{ form_row(form.experience) }}
                            {{ form_row(form.info) }}
                            <div class="d-flex justify-content-center" style="gap: 0.5rem;">
                                {# <a class="btn btn-light rounded-pill px-1 px-sm-2" href={{ path('homepage') }} role="button">Update Later</a> #}
                                <a class="btn btn-light rounded-pill px-1 px-sm-2" href={{ path('checkup_categorisation') }} role="button">Choose a Different Type</a>
                                <button type="submit" id="submit" class="btn btn-primary rounded-pill px-1 px-sm-2">Confirm Investor Type</button>
                            </div>  
                            {{ form_rest(form) }}
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </main>
{% endblock %}
