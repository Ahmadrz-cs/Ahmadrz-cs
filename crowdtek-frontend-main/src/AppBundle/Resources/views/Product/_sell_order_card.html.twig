<div class="card sell-order-card">
	<div class="card-body d-flex flex-column text-md gap-y-2">
		<div class="d-flex justify-content-between align-items-center">
			<div data-field-name="share-price">{{ order.pricePerShare|format_currency('GBP') }} / share</div>
			<div data-field-name="shares-available">{{ order.sharesAvailable|number_format(0, '.', ',') }} shares available</div>
		</div>
		<div class="d-flex justify-content-between align-items-center">
	 		<span class="badge badge-secondary badge-md rounded-md" data-field-name="offered-by">{% if order.type.value == 'initial' %}Offered by Yielders{% else %}Secondary Market{% endif %}</span>
			{% if selected|default(false) %}
				<span class="badge badge-light badge-md rounded-md">Currently Selected</span>
			{% else %}
				<a href="{{ path(app.request.get("_route"), { id: asset.id ,selected: entry.uuid }) }}">
					<span class="badge border badge-md rounded-md">Select Offer</span>
				</a>
			{% endif %}
		</div>
	</div>
</div>
